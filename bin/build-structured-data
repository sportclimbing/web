#!/usr/bin/php
<?php declare(strict_types=1);

error_reporting(E_ALL);
ini_set('display_errors', '1');

const EVENT_SCHEDULED = 'https://schema.org/EventScheduled';
const EVENT_IN_PROGRESS = 'https://schema.org/EventInProgress';
const EVENT_COMPLETED = 'https://schema.org/EventCompleted';
const DEFAULT_YOUTUBE_VIDEO_ID = 'emrHdLsJTk4';
const YOUTUBE_IMAGE_RESOLUTIONS = ['default', 'mqdefault', 'hqdefault'];

function schema_event_status(string $startsAt, string $endsAt, DateTimeImmutable $now): string
{
    try {
        $eventStart = new DateTimeImmutable($startsAt);
        $eventEnd = new DateTimeImmutable($endsAt);
    } catch (Exception) {
        return EVENT_SCHEDULED;
    }

    if ($now < $eventStart) {
        return EVENT_SCHEDULED;
    }

    if ($now > $eventEnd) {
        return EVENT_COMPLETED;
    }

    return EVENT_IN_PROGRESS;
}

function schema_event_location(array $event): array
{
    $locationName = is_string($event['location'] ?? null) ? trim($event['location']) : '';
    $country = is_string($event['country'] ?? null) ? trim($event['country']) : '';
    $name = $locationName !== '' ? $locationName : $country;

    $location = [
        '@type' => 'Place',
        'name' => $name !== '' ? $name : 'TBA',
    ];

    if ($country !== '') {
        $location['address'] = [
            '@type' => 'PostalAddress',
            'addressCountry' => $country,
        ];
    }

    return $location;
}

function schema_event_fallback_url(string $siteUrl, string $season): string
{
    return "{$siteUrl}/season/{$season}";
}

function schema_round_url(array $round, string $siteUrl, string $season): string
{
    $streamUrl = is_string($round['stream_url'] ?? null) ? trim($round['stream_url']) : '';

    if ($streamUrl !== '') {
        return $streamUrl;
    }

    return schema_event_fallback_url($siteUrl, $season);
}

function schema_round_name(array $event, array $round): string
{
    $eventName = is_string($event['name'] ?? null) ? trim($event['name']) : '';
    $roundName = is_string($round['name'] ?? null) ? trim($round['name']) : '';

    if ($eventName !== '' && $roundName !== '') {
        return "{$eventName} - {$roundName}";
    }

    if ($roundName !== '') {
        return $roundName;
    }

    return $eventName !== '' ? $eventName : 'IFSC Round';
}

function schema_round_description(array $event, array $round): string
{
    $name = schema_round_name($event, $round);
    $locationName = is_string($event['location'] ?? null) ? trim($event['location']) : '';
    $country = is_string($event['country'] ?? null) ? trim($event['country']) : '';
    $location = implode(', ', array_filter([$locationName, $country]));

    if ($location !== '') {
        return "{$name} in {$location}. Live stream links and schedule";
    }

    return "{$name}. Live stream links and schedule";
}

function schema_event_name(array $event): string
{
    $eventName = is_string($event['name'] ?? null) ? trim($event['name']) : '';

    return $eventName !== '' ? $eventName : 'IFSC Event';
}

function schema_event_description(array $event): string
{
    $eventName = schema_event_name($event);
    $locationName = is_string($event['location'] ?? null) ? trim($event['location']) : '';
    $country = is_string($event['country'] ?? null) ? trim($event['country']) : '';
    $location = implode(', ', array_filter([$locationName, $country]));

    if ($location !== '') {
        return "{$eventName} in {$location}. Live stream links and schedule";
    }

    return "{$eventName}. Live stream links and schedule";
}

function schema_slugify(string $value): string
{
    $value = trim($value);

    if ($value === '') {
        return '';
    }

    $value = function_exists('mb_strtolower') ? mb_strtolower($value, 'UTF-8') : strtolower($value);
    $slug = preg_replace('/[^a-z0-9]+/', '-', $value);

    if (!is_string($slug)) {
        return '';
    }

    return trim($slug, '-');
}

function schema_event_page_url(array $event, string $siteUrl, string $season): string
{
    $eventId = is_scalar($event['id'] ?? null) ? trim((string) $event['id']) : '';

    if ($eventId === '') {
        return schema_event_fallback_url($siteUrl, $season);
    }

    $slugSource = is_string($event['slug'] ?? null) && trim($event['slug']) !== ''
        ? trim($event['slug'])
        : schema_event_name($event);
    $slug = schema_slugify($slugSource);
    $eventIdSuffix = "-{$eventId}";

    if ($slug !== '' && str_ends_with($slug, $eventIdSuffix)) {
        $slug = (string) substr($slug, 0, -strlen($eventIdSuffix));
    }

    if ($slug === '') {
        $slug = 'event';
    }

    $seasonSegment = rawurlencode($season);
    $slugIdSegment = rawurlencode("{$slug}-{$eventId}");

    return "{$siteUrl}/season/{$seasonSegment}/event/{$slugIdSegment}";
}

function schema_performer_name(array $performer): string
{
    $firstName = is_string($performer['first_name'] ?? null) ? trim($performer['first_name']) : '';
    $lastName = is_string($performer['last_name'] ?? null) ? trim($performer['last_name']) : '';
    $name = implode(' ', array_filter([$firstName, $lastName]));

    if ($name !== '') {
        return $name;
    }

    return is_string($performer['name'] ?? null) ? trim($performer['name']) : '';
}

function schema_event_athletes(array $event): array
{
    $startList = is_array($event['start_list'] ?? null) ? $event['start_list'] : [];
    $athletes = [];

    foreach ($startList as $startListAthlete) {
        if (!is_array($startListAthlete)) {
            continue;
        }

        $name = schema_performer_name($startListAthlete);

        if ($name === '') {
            continue;
        }

        $athletes[] = [
            '@type' => 'Person',
            'name' => $name,
        ];

        if (count($athletes) >= 5) {
            break;
        }
    }

    return $athletes;
}

function schema_event_performer_team(array $event): ?array
{
    $athletes = schema_event_athletes($event);

    if (count($athletes) === 0) {
        return null;
    }

    $eventName = is_string($event['name'] ?? null) ? trim($event['name']) : '';
    $teamName = $eventName !== '' ? "{$eventName} athletes" : 'Athletes';

    return [
        '@type' => 'SportsTeam',
        'name' => $teamName,
        'athlete' => $athletes,
    ];
}

function youtube_video_id_from_url(string $url): ?string
{
    $url = trim($url);

    if ($url === '') {
        return null;
    }

    if (preg_match(
        '/(?:youtu\.be\/|youtube(?:-nocookie)?\.com\/(?:watch\?(?:.*&)?v=|live\/|embed\/|shorts\/))(?<video_id>[A-Za-z0-9_-]{10,})/i',
        $url,
        $matches
    ) !== 1) {
        return null;
    }

    return is_string($matches['video_id'] ?? null) ? $matches['video_id'] : null;
}

function schema_round_images(array $round): array
{
    $streamUrl = is_string($round['stream_url'] ?? null) ? trim($round['stream_url']) : '';
    $videoId = youtube_video_id_from_url($streamUrl) ?? DEFAULT_YOUTUBE_VIDEO_ID;
    $images = [];

    foreach (YOUTUBE_IMAGE_RESOLUTIONS as $resolution) {
        $images[] = "https://img.youtube.com/vi/{$videoId}/{$resolution}.jpg";
    }

    return $images;
}

function schema_normalize_keyword(string $keyword): string
{
    $keyword = trim($keyword);

    if ($keyword === '') {
        return '';
    }

    if (function_exists('mb_strtolower')) {
        return mb_strtolower($keyword, 'UTF-8');
    }

    return strtolower($keyword);
}

function schema_keywords(array $event, array $round): string
{
    $keywords = [schema_normalize_keyword('climbing')];

    foreach ([$round['disciplines'] ?? [], $round['categories'] ?? [], $event['disciplines'] ?? []] as $values) {
        foreach (is_array($values) ? $values : [] as $value) {
            if (is_string($value) && trim($value) !== '') {
                $keywords[] = schema_normalize_keyword($value);
            }
        }
    }

    if (is_string($round['kind'] ?? null) && trim($round['kind']) !== '') {
        $keywords[] = schema_normalize_keyword($round['kind']);
    }

    if (is_string($event['league_name'] ?? null) && trim($event['league_name']) !== '') {
        $keywords[] = schema_normalize_keyword($event['league_name']);
    }

    if (is_string($event['location'] ?? null) && trim($event['location']) !== '') {
        $keywords[] = schema_normalize_keyword($event['location']);
    }

    if (is_string($event['country'] ?? null) && trim($event['country']) !== '') {
        $keywords[] = schema_normalize_keyword($event['country']);
    }

    $keywords = array_values(array_unique($keywords));

    return implode(', ', $keywords);
}

function schema_event_keywords(array $event): string
{
    $keywords = [schema_normalize_keyword('climbing')];

    foreach ([$event['disciplines'] ?? []] as $values) {
        foreach (is_array($values) ? $values : [] as $value) {
            if (is_string($value) && trim($value) !== '') {
                $keywords[] = schema_normalize_keyword($value);
            }
        }
    }

    if (is_string($event['league_name'] ?? null) && trim($event['league_name']) !== '') {
        $keywords[] = schema_normalize_keyword($event['league_name']);
    }

    if (is_string($event['location'] ?? null) && trim($event['location']) !== '') {
        $keywords[] = schema_normalize_keyword($event['location']);
    }

    if (is_string($event['country'] ?? null) && trim($event['country']) !== '') {
        $keywords[] = schema_normalize_keyword($event['country']);
    }

    $keywords = array_values(array_unique($keywords));

    return implode(', ', $keywords);
}

function schema_file_name_token(string $value, string $fallback = 'event'): string
{
    $value = trim($value);

    if ($value === '') {
        return $fallback;
    }

    $token = preg_replace('/[^A-Za-z0-9_-]+/', '-', $value);

    if (!is_string($token)) {
        return $fallback;
    }

    $token = trim($token, '-');

    return $token !== '' ? $token : $fallback;
}

function schema_same_as_urls(array $event, string $schemaEventUrl): array
{
    $sameAs = [];
    $eventId = is_scalar($event['id'] ?? null) ? trim((string) $event['id']) : '';

    if ($eventId !== '') {
        $sameAs[] = "https://ifsc.results.info/event/{$eventId}/";
    }

    if (is_string($event['event_url'] ?? null) && trim($event['event_url']) !== '') {
        $eventUrl = trim($event['event_url']);

        if ($eventUrl !== $schemaEventUrl) {
            $sameAs[] = $eventUrl;
        }
    }

    return array_values(array_unique($sameAs));
}

function cli_usage_text(string $scriptName): string
{
    return implode(PHP_EOL, [
        'Usage:',
        "  php {$scriptName} [--events-dir <dir>] [--output-dir <dir>] [--site-url <url>] [--minify|--pretty|--no-minify]",
        "  php {$scriptName} [events-dir] [output-dir] [site-url] [minify]",
        '',
        'Minify values:',
        '  1,true,yes,on,minify,minified,compact',
        '  0,false,no,off,pretty,pretty-print,prettyprint',
    ]) . PHP_EOL;
}

function print_usage_and_exit(string $scriptName, int $exitCode = 0): void
{
    $usageText = cli_usage_text($scriptName);

    if ($exitCode === 0) {
        fwrite(STDOUT, $usageText);
    } else {
        fwrite(STDERR, $usageText);
    }

    exit($exitCode);
}

function fail_with_usage(array $argv, string $message): void
{
    $scriptName = basename((string) ($argv[0] ?? 'build-structured-data'));
    fwrite(STDERR, $message . PHP_EOL);
    print_usage_and_exit($scriptName, 1);
}

function parse_boolean_flag_value(string $argument, string $optionName): bool
{
    $value = strtolower(trim($argument));
    $truthyValues = ['1', 'true', 'yes', 'on'];
    $falsyValues = ['0', 'false', 'no', 'off'];

    if (in_array($value, $truthyValues, true)) {
        return true;
    }

    if (in_array($value, $falsyValues, true)) {
        return false;
    }

    fwrite(
        STDERR,
        "Invalid value for --{$optionName}: {$argument}" . PHP_EOL
        . 'Use one of: 1,true,yes,on,0,false,no,off' . PHP_EOL
    );
    exit(1);
}

function parse_minify_argument(?string $argument): bool
{
    if ($argument === null) {
        return true;
    }

    $value = strtolower(trim($argument));
    $truthyValues = ['1', 'true', 'yes', 'on', 'minify', 'minified', 'compact'];
    $falsyValues = ['0', 'false', 'no', 'off', 'pretty', 'pretty-print', 'prettyprint'];

    if (in_array($value, $truthyValues, true)) {
        return true;
    }

    if (in_array($value, $falsyValues, true)) {
        return false;
    }

    fwrite(
        STDERR,
        "Invalid minify argument: {$argument}" . PHP_EOL
        . "Use one of: 1,true,yes,on,minify,minified,compact,0,false,no,off,pretty,pretty-print,prettyprint" . PHP_EOL
    );
    exit(1);
}

function parse_cli_options(array $argv): array
{
    $options = [];
    $positional = [];
    $argumentCount = count($argv);

    for ($index = 1; $index < $argumentCount; $index++) {
        $argument = (string) $argv[$index];

        if ($argument === '-h' || $argument === '--help') {
            $scriptName = basename((string) ($argv[0] ?? 'build-structured-data'));
            print_usage_and_exit($scriptName);
        }

        if ($argument === '--') {
            for ($restIndex = $index + 1; $restIndex < $argumentCount; $restIndex++) {
                $positional[] = (string) $argv[$restIndex];
            }
            break;
        }

        if (!str_starts_with($argument, '--')) {
            $positional[] = $argument;
            continue;
        }

        $optionBody = substr($argument, 2);

        if ($optionBody === '') {
            fail_with_usage($argv, 'Invalid option: --');
        }

        if (str_contains($optionBody, '=')) {
            [$optionName, $optionValue] = explode('=', $optionBody, 2);
        } else {
            $optionName = $optionBody;
            $optionValue = null;
        }

        if (!is_string($optionName) || trim($optionName) === '') {
            fail_with_usage($argv, "Invalid option format: {$argument}");
        }

        $optionName = trim($optionName);

        if (in_array($optionName, ['events-dir', 'output-dir', 'site-url'], true)) {
            if ($optionValue === null) {
                $nextArgument = $argv[$index + 1] ?? null;

                if (!is_string($nextArgument) || str_starts_with($nextArgument, '--')) {
                    fail_with_usage($argv, "Missing value for --{$optionName}");
                }

                $optionValue = $nextArgument;
                $index++;
            }

            $optionKey = str_replace('-', '_', $optionName);
            $options[$optionKey] = $optionValue;
            continue;
        }

        if ($optionName === 'minify') {
            if ($optionValue === null) {
                $nextArgument = $argv[$index + 1] ?? null;

                if (is_string($nextArgument) && !str_starts_with($nextArgument, '--')) {
                    $optionValue = $nextArgument;
                    $index++;
                } else {
                    $optionValue = 'true';
                }
            }

            $options['minify'] = $optionValue;
            continue;
        }

        if ($optionName === 'pretty') {
            if ($optionValue !== null) {
                $enablePretty = parse_boolean_flag_value($optionValue, 'pretty');
                $options['minify'] = $enablePretty ? 'false' : 'true';
            } else {
                $options['minify'] = 'false';
            }
            continue;
        }

        if ($optionName === 'no-minify') {
            if ($optionValue !== null) {
                $disableMinify = parse_boolean_flag_value($optionValue, 'no-minify');
                $options['minify'] = $disableMinify ? 'false' : 'true';
            } else {
                $options['minify'] = 'false';
            }
            continue;
        }

        fail_with_usage($argv, "Unknown option: --{$optionName}");
    }

    return [
        'options' => $options,
        'positional' => $positional,
    ];
}

$cliArguments = parse_cli_options($argv);
$namedOptions = is_array($cliArguments['options'] ?? null) ? $cliArguments['options'] : [];
$positionalArguments = is_array($cliArguments['positional'] ?? null) ? $cliArguments['positional'] : [];

$eventsDirectory = rtrim(
    isset($namedOptions['events_dir'])
        ? (string) $namedOptions['events_dir']
        : (count($positionalArguments) > 0 ? (string) array_shift($positionalArguments) : 'events'),
    '/'
);
$outputDirectory = rtrim(
    isset($namedOptions['output_dir'])
        ? (string) $namedOptions['output_dir']
        : (count($positionalArguments) > 0 ? (string) array_shift($positionalArguments) : 'public/structured-data'),
    '/'
);
$siteUrl = rtrim(
    isset($namedOptions['site_url'])
        ? (string) $namedOptions['site_url']
        : (count($positionalArguments) > 0 ? (string) array_shift($positionalArguments) : 'https://ifsc.stream'),
    '/'
);
$minifyArgument = isset($namedOptions['minify'])
    ? (string) $namedOptions['minify']
    : (count($positionalArguments) > 0 ? (string) array_shift($positionalArguments) : null);

if (count($positionalArguments) > 0) {
    fail_with_usage($argv, 'Too many positional arguments provided.');
}

$minifyJson = parse_minify_argument($minifyArgument);
$jsonEncodeFlags = JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR;

if (!$minifyJson) {
    $jsonEncodeFlags |= JSON_PRETTY_PRINT;
}

$organizationId = "{$siteUrl}/#organization";
$now = new DateTimeImmutable('now');

if (!is_dir($eventsDirectory)) {
    fwrite(STDERR, "Events directory not found: {$eventsDirectory}" . PHP_EOL);
    exit(1);
}

if (!is_dir($outputDirectory) && !mkdir($outputDirectory, 0777, true) && !is_dir($outputDirectory)) {
    fwrite(STDERR, "Could not create output directory: {$outputDirectory}" . PHP_EOL);
    exit(1);
}

$eventFiles = glob("{$eventsDirectory}/events_*.json");

if ($eventFiles === false || count($eventFiles) === 0) {
    fwrite(STDERR, "No event files found in {$eventsDirectory}" . PHP_EOL);
    exit(1);
}

sort($eventFiles, SORT_STRING);

foreach ($eventFiles as $eventFile) {
    if (!preg_match('/events_(\d{4})\.json$/', $eventFile, $matches)) {
        continue;
    }

    $season = $matches[1];

    try {
        $payload = json_decode((string) file_get_contents($eventFile), true, flags: JSON_THROW_ON_ERROR);
    } catch (JsonException $exception) {
        fwrite(STDERR, "Could not parse {$eventFile}: {$exception->getMessage()}" . PHP_EOL);
        exit(1);
    }

    $events = array_values(array_filter(
        $payload['events'] ?? [],
        static fn($event): bool => is_array($event)
            && isset($event['id'], $event['name'])
    ));

    if (count($events) === 0) {
        continue;
    }

    $seriesStartDate = null;
    $seriesEndDate = null;
    $seriesStart = null;
    $seriesEnd = null;
    $sportsEvents = [];
    $subEvents = [];

    foreach ($events as $event) {
        $eventId = trim((string) $event['id']);
        $rounds = is_array($event['rounds'] ?? null) ? $event['rounds'] : [];
        $eventPerformerTeam = schema_event_performer_team($event);
        $eventStartDate = null;
        $eventEndDate = null;
        $eventStart = null;
        $eventEnd = null;
        $eventSportsEvents = [];
        $eventSubEvents = [];

        foreach ($rounds as $roundIndex => $round) {
            if (!is_array($round) || !isset($round['starts_at'], $round['ends_at'])) {
                continue;
            }

            $startsAt = (string) $round['starts_at'];
            $endsAt = (string) $round['ends_at'];
            $schemaId = "{$siteUrl}/#round-{$season}-{$eventId}-" . ($roundIndex + 1);

            try {
                $roundStart = new DateTimeImmutable($startsAt);
                $roundEnd = new DateTimeImmutable($endsAt);
            } catch (Exception) {
                fwrite(STDERR, "Skipping round " . ($roundIndex + 1) . " for event {$eventId} in season {$season}: invalid dates" . PHP_EOL);
                continue;
            }

            if ($seriesStart === null || $roundStart < $seriesStart) {
                $seriesStart = $roundStart;
                $seriesStartDate = $startsAt;
            }

            if ($seriesEnd === null || $roundEnd > $seriesEnd) {
                $seriesEnd = $roundEnd;
                $seriesEndDate = $endsAt;
            }

            if ($eventStart === null || $roundStart < $eventStart) {
                $eventStart = $roundStart;
                $eventStartDate = $startsAt;
            }

            if ($eventEnd === null || $roundEnd > $eventEnd) {
                $eventEnd = $roundEnd;
                $eventEndDate = $endsAt;
            }

            $schemaEvent = [
                '@type' => 'SportsEvent',
                '@id' => $schemaId,
                'name' => schema_round_name($event, $round),
                'description' => schema_round_description($event, $round),
                'sport' => 'Sport climbing',
                'startDate' => $startsAt,
                'endDate' => $endsAt,
                'eventStatus' => schema_event_status($startsAt, $endsAt, $now),
                'eventAttendanceMode' => 'https://schema.org/MixedEventAttendanceMode',
                'organizer' => [
                    '@id' => $organizationId,
                ],
                'location' => schema_event_location($event),
                'image' => schema_round_images($round),
                'url' => schema_round_url($round, $siteUrl, $season),
            ];

            if ($eventPerformerTeam !== null) {
                $schemaEvent['performer'] = $eventPerformerTeam;
            }

            if (is_string($event['league_name'] ?? null) && trim($event['league_name']) !== '') {
                $schemaEvent['eventType'] = trim($event['league_name']);
            } elseif (is_string($round['kind'] ?? null) && trim($round['kind']) !== '') {
                $schemaEvent['eventType'] = trim($round['kind']);
            }

            $keywords = schema_keywords($event, $round);

            if ($keywords !== '') {
                $schemaEvent['keywords'] = $keywords;
            }

            $sameAs = schema_same_as_urls($event, $schemaEvent['url']);

            if (count($sameAs) > 0) {
                $schemaEvent['sameAs'] = $sameAs;
            }

            $sportsEvents[] = $schemaEvent;
            $subEvents[] = [
                '@id' => $schemaId,
            ];
            $eventSportsEvents[] = $schemaEvent;
            $eventSubEvents[] = [
                '@id' => $schemaId,
            ];
        }

        if (count($eventSportsEvents) === 0 || $eventStartDate === null || $eventEndDate === null) {
            continue;
        }

        $eventSchemaUrl = schema_event_page_url($event, $siteUrl, $season);
        $eventSchemaId = "{$siteUrl}/#event-{$season}-{$eventId}";
        $eventSchema = [
            '@type' => 'SportsEvent',
            '@id' => $eventSchemaId,
            'name' => schema_event_name($event),
            'description' => schema_event_description($event),
            'sport' => 'Sport climbing',
            'startDate' => $eventStartDate,
            'endDate' => $eventEndDate,
            'eventStatus' => schema_event_status($eventStartDate, $eventEndDate, $now),
            'eventAttendanceMode' => 'https://schema.org/MixedEventAttendanceMode',
            'organizer' => [
                '@id' => $organizationId,
            ],
            'location' => schema_event_location($event),
            'url' => $eventSchemaUrl,
            'subEvent' => $eventSubEvents,
        ];

        if ($eventPerformerTeam !== null) {
            $eventSchema['performer'] = $eventPerformerTeam;
        }

        if (is_string($event['league_name'] ?? null) && trim($event['league_name']) !== '') {
            $eventSchema['eventType'] = trim($event['league_name']);
        }

        $eventKeywords = schema_event_keywords($event);

        if ($eventKeywords !== '') {
            $eventSchema['keywords'] = $eventKeywords;
        }

        $eventSameAs = schema_same_as_urls($event, $eventSchemaUrl);

        if (count($eventSameAs) > 0) {
            $eventSchema['sameAs'] = $eventSameAs;
        }

        $eventPrimaryImage = $eventSportsEvents[0]['image'] ?? null;

        if (is_array($eventPrimaryImage) && count($eventPrimaryImage) > 0) {
            $eventSchema['image'] = $eventPrimaryImage;
        }

        $eventGraph = [
            '@context' => 'https://schema.org',
            '@graph' => array_merge([$eventSchema], $eventSportsEvents),
        ];
        $eventIdToken = schema_file_name_token($eventId);
        $eventOutputFile = "{$outputDirectory}/events_{$season}_{$eventIdToken}.json";
        $eventOutputJson = json_encode($eventGraph, $jsonEncodeFlags);
        file_put_contents($eventOutputFile, $eventOutputJson . PHP_EOL);

        echo "[+] Built structured data for event {$eventId} ({$season}): {$eventOutputFile}" . PHP_EOL;
    }

    if (count($sportsEvents) === 0) {
        continue;
    }

    $seasonSchemaId = "{$siteUrl}/#season-{$season}";
    $graph = [
        '@context' => 'https://schema.org',
        '@graph' => array_merge(
            [
                [
                    '@type' => 'EventSeries',
                    '@id' => $seasonSchemaId,
                    'name' => "World Climbing Season {$season}",
                    'description' => "Competition climbing season schedule and live stream links for {$season}.",
                    'url' => "{$siteUrl}/season/{$season}",
                    'organizer' => [
                        '@id' => $organizationId,
                    ],
                    'startDate' => $seriesStartDate,
                    'endDate' => $seriesEndDate,
                    'subEvent' => $subEvents,
                ],
            ],
            $sportsEvents
        ),
    ];

    $outputFile = "{$outputDirectory}/events_{$season}.json";
    $outputJson = json_encode($graph, $jsonEncodeFlags);
    file_put_contents($outputFile, $outputJson . PHP_EOL);

    echo "[+] Built structured data for season {$season}: {$outputFile}" . PHP_EOL;
}
