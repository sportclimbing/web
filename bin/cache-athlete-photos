#!/usr/bin/php
<?php declare(strict_types=1);

error_reporting(E_ALL);
ini_set('display_errors', '1');

const DEFAULT_IMAGE_SIZE = 128;
const DEFAULT_IMAGE_QUALITY = 82;
const DEFAULT_HTTP_TIMEOUT_SECONDS = 20;

function usage(string $script): string
{
    return <<<TXT
Usage:
  php {$script} [events-dir] [images-dir] [image-size]

Arguments:
  events-dir           Directory containing events_YYYY.json (default: public/events)
  images-dir           Output directory for local images (default: public/img/athletes)
  image-size           Square output size in px (default: 128)

Example:
  php {$script}
TXT;
}

function normalize_athlete_id(mixed $athleteId): string
{
    if (!is_scalar($athleteId)) {
        return '';
    }

    $athleteIdString = trim((string) $athleteId);

    if ($athleteIdString === '') {
        return '';
    }

    if (preg_match('/^\d+$/', $athleteIdString) === 1) {
        return $athleteIdString;
    }

    return '';
}

function decode_events_file(string $eventsFile): array
{
    if (!is_file($eventsFile)) {
        throw new RuntimeException("Events file not found: {$eventsFile}");
    }

    $contents = file_get_contents($eventsFile);

    if ($contents === false) {
        throw new RuntimeException("Could not read events file: {$eventsFile}");
    }

    try {
        $payload = json_decode($contents, true, flags: JSON_THROW_ON_ERROR);
    } catch (JsonException $exception) {
        throw new RuntimeException("Could not parse {$eventsFile}: {$exception->getMessage()}");
    }

    if (!is_array($payload)) {
        throw new RuntimeException("Events payload is not a JSON object: {$eventsFile}");
    }

    return $payload;
}

function fetch_binary(string $url): string
{
    $url = trim($url);

    if ($url === '') {
        throw new RuntimeException('Photo URL is empty');
    }

    if (function_exists('curl_init')) {
        $ch = curl_init($url);

        if ($ch === false) {
            throw new RuntimeException('Could not initialize curl');
        }

        curl_setopt_array($ch, [
            CURLOPT_FOLLOWLOCATION => true,
            CURLOPT_CONNECTTIMEOUT => DEFAULT_HTTP_TIMEOUT_SECONDS,
            CURLOPT_TIMEOUT => DEFAULT_HTTP_TIMEOUT_SECONDS,
            CURLOPT_RETURNTRANSFER => true,
            CURLOPT_FAILONERROR => false,
            CURLOPT_HTTPHEADER => [
                'Accept: image/*',
                'User-Agent: ifsc.stream-athlete-photo-cache/1.0',
            ],
        ]);

        $body = curl_exec($ch);
        $status = (int) curl_getinfo($ch, CURLINFO_HTTP_CODE);
        $error = curl_error($ch);

        if ($body === false) {
            throw new RuntimeException("Download failed: {$error}");
        }

        if ($status < 200 || $status >= 300) {
            throw new RuntimeException("Unexpected HTTP status {$status}");
        }

        return $body;
    }

    $context = stream_context_create([
        'http' => [
            'method' => 'GET',
            'timeout' => DEFAULT_HTTP_TIMEOUT_SECONDS,
            'header' => "Accept: image/*\r\nUser-Agent: ifsc.stream-athlete-photo-cache/1.0\r\n",
        ],
    ]);

    $body = file_get_contents($url, false, $context);

    if ($body === false) {
        throw new RuntimeException('Download failed');
    }

    return $body;
}

function save_resized_square_jpeg(string $binary, string $destination, int $size, int $quality): void
{
    $sourceImage = @imagecreatefromstring($binary);

    if ($sourceImage === false) {
        throw new RuntimeException('Unsupported or invalid image format');
    }

    $sourceWidth = imagesx($sourceImage);
    $sourceHeight = imagesy($sourceImage);

    if ($sourceWidth <= 0 || $sourceHeight <= 0) {
        throw new RuntimeException('Image dimensions are invalid');
    }

    $cropSize = min($sourceWidth, $sourceHeight);
    $sourceX = (int) floor(($sourceWidth - $cropSize) / 2);
    $sourceY = (int) floor(($sourceHeight - $cropSize) / 2);

    $targetImage = imagecreatetruecolor($size, $size);

    if ($targetImage === false) {
        throw new RuntimeException('Could not allocate output image');
    }

    imagecopyresampled(
        $targetImage,
        $sourceImage,
        0,
        0,
        $sourceX,
        $sourceY,
        $size,
        $size,
        $cropSize,
        $cropSize
    );

    if (!imagejpeg($targetImage, $destination, $quality)) {
        throw new RuntimeException("Could not write image: {$destination}");
    }
}

function start_list_photo_entries(array $payload): array
{
    $events = $payload['events'] ?? [];

    if (!is_array($events)) {
        return [];
    }

    $entries = [];

    foreach ($events as $event) {
        if (!is_array($event)) {
            continue;
        }

        $startList = $event['start_list'] ?? [];

        if (!is_array($startList)) {
            continue;
        }

        foreach ($startList as $athlete) {
            if (!is_array($athlete)) {
                continue;
            }

            $athleteId = normalize_athlete_id($athlete['athlete_id'] ?? null);
            $photoUrl = is_string($athlete['photo_url'] ?? null) ? trim($athlete['photo_url']) : '';

            if ($photoUrl === '') {
                continue;
            }

            $entries[] = [
                'athlete_id' => $athleteId,
                'photo_url' => $photoUrl,
            ];
        }
    }

    return $entries;
}

function local_filename_from_photo_url(string $photoUrl): string
{
    $path = parse_url($photoUrl, PHP_URL_PATH);

    if (!is_string($path) || $path === '') {
        throw new RuntimeException("Could not extract a file path from photo URL: {$photoUrl}");
    }

    $fileName = trim(basename($path));

    if ($fileName === '' || $fileName === '.' || $fileName === '..') {
        throw new RuntimeException("Could not extract a valid filename from photo URL: {$photoUrl}");
    }

    if (str_contains($fileName, "\0")) {
        throw new RuntimeException("Invalid filename extracted from photo URL: {$photoUrl}");
    }

    $baseName = pathinfo($fileName, PATHINFO_FILENAME);

    if ($baseName === '' || $baseName === '.' || $baseName === '..') {
        $baseName = $fileName;
    }

    return "{$baseName}.jpg";
}

function discover_event_files(string $eventsDirectory): array
{
    $eventFiles = glob("{$eventsDirectory}/events_*.json");

    if ($eventFiles === false || count($eventFiles) === 0) {
        throw new RuntimeException("No events_YYYY.json files found in {$eventsDirectory}");
    }

    $eventFileBySeason = [];

    foreach ($eventFiles as $eventFile) {
        if (preg_match('/events_(\d{4})\.json$/', basename($eventFile), $matches) !== 1) {
            continue;
        }

        $eventFileBySeason[$matches[1]] = $eventFile;
    }

    if (count($eventFileBySeason) === 0) {
        throw new RuntimeException("No valid events_YYYY.json files found in {$eventsDirectory}");
    }

    // Prefer latest-season data when the same photo filename appears across seasons.
    krsort($eventFileBySeason, SORT_NUMERIC);

    return $eventFileBySeason;
}

if (!extension_loaded('gd')) {
    fwrite(STDERR, "GD extension is required (missing 'gd')." . PHP_EOL);
    exit(1);
}

try {
    if (count($argv) > 4) {
        throw new InvalidArgumentException('Too many arguments provided');
    }

    $eventsDirectory = rtrim($argv[1] ?? 'public/events', '/');
    $imagesDirectory = rtrim($argv[2] ?? 'public/img/athletes', '/');
    $imageSize = (int) ($argv[3] ?? (string) DEFAULT_IMAGE_SIZE);

    if ($imageSize < 32 || $imageSize > 1024) {
        throw new InvalidArgumentException('Image size must be between 32 and 1024 pixels');
    }
} catch (Throwable $exception) {
    fwrite(STDERR, $exception->getMessage() . PHP_EOL);
    fwrite(STDERR, usage($argv[0] ?? 'bin/cache-athlete-photos') . PHP_EOL);
    exit(1);
}

try {
    $eventFileBySeason = discover_event_files($eventsDirectory);
} catch (Throwable $exception) {
    fwrite(STDERR, $exception->getMessage() . PHP_EOL);
    exit(1);
}

$photoCandidates = [];
$deduplicatedByFilenameCount = 0;
$invalidFilenameCount = 0;

foreach ($eventFileBySeason as $season => $eventsFile) {
    try {
        $payload = decode_events_file($eventsFile);
    } catch (Throwable $exception) {
        fwrite(STDERR, $exception->getMessage() . PHP_EOL);
        exit(1);
    }

    foreach (start_list_photo_entries($payload) as $entry) {
        $photoUrl = $entry['photo_url'];
        $athleteId = $entry['athlete_id'];
        $fileName = '';

        try {
            $fileName = local_filename_from_photo_url($photoUrl);
        } catch (Throwable $exception) {
            $invalidFilenameCount++;
            fwrite(STDERR, "[!] Skipping photo URL {$photoUrl}: {$exception->getMessage()}" . PHP_EOL);
            continue;
        }

        if (!array_key_exists($fileName, $photoCandidates)) {
            $photoCandidates[$fileName] = [
                'season' => $season,
                'athlete_id' => $athleteId,
                'photo_url' => $photoUrl,
                'file_name' => $fileName,
            ];
            continue;
        }

        if ($photoCandidates[$fileName]['photo_url'] !== $photoUrl) {
            $deduplicatedByFilenameCount++;
        }

        if ($photoCandidates[$fileName]['athlete_id'] === '' && $athleteId !== '') {
            $photoCandidates[$fileName]['athlete_id'] = $athleteId;
        }
    }
}

$candidateCount = count($photoCandidates);

if ($candidateCount === 0) {
    echo "[+] No start-list athlete photos found in " . count($eventFileBySeason) . " events_YYYY.json files." . PHP_EOL;
    exit(0);
}

$writtenCount = 0;
$downloadedCount = 0;
$failedCount = 0;

if (!is_dir($imagesDirectory) && !mkdir($imagesDirectory, 0777, true) && !is_dir($imagesDirectory)) {
    fwrite(STDERR, "Could not create output directory: {$imagesDirectory}" . PHP_EOL);
    exit(1);
}

foreach ($photoCandidates as $candidate) {
    $season = $candidate['season'];
    $athleteId = $candidate['athlete_id'];
    $photoUrl = $candidate['photo_url'];
    $destinationFileName = $candidate['file_name'];

    try {
        $destination = "{$imagesDirectory}/{$destinationFileName}";

        $binary = fetch_binary($photoUrl);
        save_resized_square_jpeg($binary, $destination, $imageSize, DEFAULT_IMAGE_QUALITY);
        $writtenCount++;
        $downloadedCount++;
        $label = $athleteId !== '' ? "athlete {$athleteId}" : "photo {$destinationFileName}";
        echo "[+] Cached {$label} (season {$season}) -> {$destination}" . PHP_EOL;
    } catch (Throwable $exception) {
        $failedCount++;
        $label = $athleteId !== '' ? "athlete {$athleteId}" : "photo URL {$photoUrl}";
        fwrite(STDERR, "[!] Could not cache {$label} (season {$season}): {$exception->getMessage()}" . PHP_EOL);
    }
}

if ($writtenCount === 0) {
    fwrite(STDERR, "[!] Failed to cache all {$candidateCount} athlete photos." . PHP_EOL);
    exit(1);
}

$seasonCount = count($eventFileBySeason);
echo "[+] Cached {$writtenCount}/{$candidateCount} unique photos across {$seasonCount} seasons ({$downloadedCount} downloaded, {$failedCount} failed, {$deduplicatedByFilenameCount} filename duplicates omitted, {$invalidFilenameCount} invalid URLs skipped)." . PHP_EOL;
