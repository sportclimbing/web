{
  "name": "world-climbing-schedule-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "cache:thumbnails": "node bin/cache-youtube-thumbnails.mjs",
    "build:js": "node bin/build-js-bundle.mjs",
    "build:js:min": "node bin/build-js-bundle.mjs --minify",
    "build:modals-css": "node bin/build-modals-css.mjs",
    "build:modals-css:min": "node bin/build-modals-css.mjs --minify",
    "build:astro": "astro build",
    "build:tailwind": "tailwindcss -i src/styles/tailwind.css -o public/css/tailwind.css",
    "dev": "npm run build:js && npm run build:modals-css && npm run build:tailwind && astro dev",
    "build": "npm run build:js:min && npm run build:modals-css:min && npm run build:tailwind -- --minify && npm run build:astro",
    "preview": "astro preview",
    "test:integration": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "astro": "6.1.3",
    "autoprefixer": "^10.4.27",
    "esbuild": "0.28.0",
    "http-server": "14.1.1",
    "postcss": "^8.5.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19"
  }
}
