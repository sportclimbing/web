---
import CalendarPage from '../components/CalendarPage.astro';
import {
  getAllSeasons,
  getSeasonEventsPayload,
} from '../lib/events-data';
import { DEFAULT_SEASON } from '../lib/config';

const season = DEFAULT_SEASON;
const seasons = getAllSeasons();
const eventsPayload = getSeasonEventsPayload(season);
const pageTitle = `IFSC Climbing World Cup ${season} Schedule – Boulder, Lead & Speed | Calendar and Live Streams`;
const pageDescription = `Full IFSC climbing calendar ${season}. World Cup schedule, live streams, results and dates for Boulder, Lead & Speed events worldwide.`;
const socialImagePath = `/img/season/${season}.svg`;
const socialImageAlt = `World Climbing ${season} season calendar preview`;
---
<CalendarPage
  season={season}
  seasons={seasons}
  eventsPayload={eventsPayload}
  canonicalPath="/"
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  socialImagePath={socialImagePath}
  socialImageAlt={socialImageAlt}
/>
