---
import AppFooter from '../../components/AppFooter.astro';
import CookieConsent from '../../components/CookieConsent.astro';
import AppHeader from '../../components/AppHeader.astro';
import CardTemplates from '../../components/CardTemplates.astro';
import Modals from '../../components/Modals.astro';
import { DEFAULT_SEASON } from '../../lib/config';
import { siteAssetVersion } from '../../lib/site-shell';

const season = DEFAULT_SEASON;
const faqItems = [
  {
    question: 'Where can I watch World Climbing events live?',
    answer: 'Each event card includes direct stream links for every published round, plus updates when streams go live. Please note that many broadcasts are geo-restricted; viewers outside the United States may need a VPN to access certain streams.',
  },
  {
    question: 'Can I sync this calendar with my device?',
    answer: 'Yes. Use the "Add to Calendar" option to subscribe so event updates are delivered automatically to your phone, tablet, or desktop calendar app.',
  },
  {
    question: 'Are start times shown in my local timezone?',
    answer: 'Yes. Round times and countdowns are rendered in your browser timezone so you can follow live sessions accurately.',
  },
  {
    question: 'Can I filter events by discipline, category, or competition type?',
    answer: 'Yes. Open Filters to narrow the calendar by disciplines, men/women categories, competition type, and stream availability.',
  },
  {
    question: 'Do I need to refresh the page when schedule data changes?',
    answer: 'Usually no. The page checks for new site versions every minute and shows a reload prompt when a fresh build is available.',
  },
  {
    question: 'Is this an official World Climbing website?',
    answer: 'No. This independent fan project was created and is maintained by (@nicoswd). Follow updates on Instagram at https://www.instagram.com/nicoswd/ and browse the code on GitHub at https://github.com/sportclimbing.',
    answerHtml: 'No. This independent fan project was created and is maintained by <a href="https://www.instagram.com/nicoswd/" target="_blank" rel="noopener" class="text-primary hover:underline">@nicoswd</a>. Follow updates on <a href="https://www.instagram.com/nicoswd/" target="_blank" rel="noopener" class="text-primary hover:underline">Instagram</a> and browse the code on <a href="https://github.com/sportclimbing" target="_blank" rel="noopener" class="text-primary hover:underline">GitHub</a>.',
  },
  {
    question: 'How can I support this project?',
    answer: 'You can support by buying me a coffee, starring the project on GitHub, and sharing the site with other competition climbing fans.',
  },
];
const pageTitle = `World Climbing ${season} Calendar Guide & FAQ | ifsc.stream`;
const pageDescription = `Find stream, timezone, filtering, and schedule answers for the World Climbing ${season} calendar.`;
const canonicalUrl = 'https://ifsc.stream/faq/';
const socialImageUrl = `https://ifsc.stream/img/season/${season}.svg`;
---
<!doctype html>
<html class="dark" lang="en">
<head>
  <meta charset="utf-8" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <base href="/" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="preconnect" href="https://api.github.com" />
  <link rel="preconnect" href="https://calendar.ifsc.stream" />
  <link rel="preconnect" href="https://buttons.github.io" />
  <link rel="preconnect" href="https://img.youtube.com" />

  <script is:inline src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

  <link rel="stylesheet" href={`/css/modals.css?v=${siteAssetVersion}`} />

  <script is:inline id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "tertiary-fixed-dim": "#ffba38",
            "secondary-fixed-dim": "#ffb3b2",
            "primary-fixed-dim": "#95ccff",
            "surface": "#101418",
            "surface-dim": "#101418",
            "surface-bright": "#36393f",
            "on-background": "#e0e2e9",
            "secondary-fixed": "#ffdad9",
            "on-tertiary-container": "#573b00",
            "on-error": "#690005",
            "background": "#101418",
            "inverse-primary": "#00639a",
            "error": "#ffb4ab",
            "on-tertiary-fixed-variant": "#604100",
            "secondary-container": "#9f0224",
            "tertiary-fixed": "#ffdeac",
            "surface-variant": "#31353a",
            "on-tertiary": "#432c00",
            "surface-container": "#1c2025",
            "tertiary": "#ffbb3d",
            "surface-container-highest": "#31353a",
            "outline": "#8a919b",
            "on-error-container": "#ffdad6",
            "on-tertiary-fixed": "#281900",
            "on-primary-fixed": "#001d32",
            "primary-fixed": "#cde5ff",
            "on-surface-variant": "#c0c7d1",
            "tertiary-container": "#e39f00",
            "outline-variant": "#404750",
            "surface-container-high": "#262a2f",
            "secondary": "#ffb3b2",
            "primary-container": "#66b2f2",
            "on-primary": "#003352",
            "inverse-on-surface": "#2d3136",
            "error-container": "#93000a",
            "on-secondary-fixed-variant": "#920020",
            "on-secondary-fixed": "#410009",
            "surface-container-low": "#181c21",
            "surface-container-lowest": "#0a0f13",
            "primary": "#66b2f2",
            "inverse-surface": "#e0e2e9",
            "on-primary-fixed-variant": "#004a75",
            "surface-tint": "#95ccff",
            "on-secondary-container": "#ffa8a8",
            "on-secondary": "#680014",
            "on-surface": "#e0e2e9",
            "on-primary-container": "#00436a"
          },
          "borderRadius": {
            "DEFAULT": "0.25rem",
            "lg": "0.5rem",
            "xl": "0.75rem",
            "full": "9999px"
          },
          "fontFamily": {
            "headline": ["Space Grotesk"],
            "body": ["Plus Jakarta Sans"],
            "label": ["Space Grotesk"]
          }
        },
      },
    }
  </script>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #101418; color: #e0e2e9; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #101418; }
    ::-webkit-scrollbar-thumb { background: #31353a; border-radius: 4px; }
    .glass-panel {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .hero-gradient {
      background: radial-gradient(circle at center, rgba(102, 178, 242, 0.1) 0%, transparent 70%);
    }
    .faq-entry.is-open .faq-answer { max-height: 20rem; }
    .faq-entry.is-open .faq-trigger { padding-left: 1rem; padding-right: 1rem; background-color: rgb(24 28 33); }
    .faq-entry.is-open .faq-trigger span:first-child { color: #66b2f2; }
    .faq-entry.is-open .faq-trigger .material-symbols-outlined { transform: rotate(180deg); color: #66b2f2; }
  </style>

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="ifsc.stream" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:image" content={socialImageUrl} />
  <meta property="og:image:alt" content={`World Climbing ${season} season calendar preview`} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={socialImageUrl} />
  <meta name="twitter:image:alt" content={`World Climbing ${season} season calendar preview`} />

  <script type="application/ld+json" id="structured-data-organization">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://ifsc.stream/#organization",
      "name": "ifsc.stream",
      "url": "https://ifsc.stream/",
      "logo": "https://ifsc.stream/img/logo.png",
      "sameAs": [
        "https://github.com/sportclimbing/ifsc-calendar",
        "https://www.instagram.com/nicoswd/"
      ]
    }
  </script>
  <script
    type="application/ld+json"
    id="structured-data-faq"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    })}
  ></script>
  <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon.png" id="favicon" />
</head>
<body class="bg-background text-on-background min-h-screen flex flex-col selection:bg-primary/30" data-page-type="faq" data-build-version={siteAssetVersion}>

<AppHeader />

<main class="pt-16 flex-1">

  <!-- Hero Section -->
  <section class="relative py-24 md:py-32 overflow-hidden hero-gradient">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <a href="/" class="inline-flex items-center gap-2 text-primary font-label font-bold text-xs uppercase tracking-widest hover:underline mb-8">
        <span class="material-symbols-outlined text-base">arrow_back</span>
        Back to Calendar
      </a>
      <h1 class="font-headline text-6xl md:text-8xl font-black tracking-tighter mb-12 text-on-surface uppercase">FAQ</h1>
      <div class="max-w-2xl mx-auto relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-primary/20 to-primary/0 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative flex items-center glass-panel rounded-2xl overflow-hidden shadow-2xl">
          <span class="material-symbols-outlined absolute left-6 text-outline group-focus-within:text-primary transition-colors">search</span>
          <label for="faq-search" class="sr-only">Search questions</label>
          <input
            id="faq-search"
            class="w-full bg-transparent border-none py-6 pl-16 pr-8 text-lg font-body focus:ring-0 transition-all placeholder:text-outline/40"
            placeholder="Search questions..."
            type="text"
            autocomplete="off"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Items -->
  <section class="max-w-4xl mx-auto px-6 pb-32" aria-labelledby="faq-section-title">
    <h2 id="faq-section-title" class="sr-only">Frequently Asked Questions</h2>
    <div class="space-y-2" id="faq-list">
      {faqItems.map((item) => (
        <div class="faq-entry border-b border-outline-variant/10">
          <button class="faq-trigger w-full py-8 flex items-center justify-between text-left transition-all duration-300 rounded-xl hover:bg-surface-container-low hover:px-4">
            <span class="font-headline font-bold text-xl md:text-2xl text-on-surface transition-colors pr-4">
              {item.question}
            </span>
            <span class="material-symbols-outlined text-outline transition-all duration-300 shrink-0">
              expand_more
            </span>
          </button>
          <div class="faq-answer overflow-hidden max-h-0 transition-all duration-500 ease-in-out px-4">
            <p class="pb-8 text-on-surface-variant font-body leading-relaxed text-lg" set:html={item.answerHtml || item.answer}></p>
          </div>
        </div>
      ))}
    </div>
    <p id="faq-no-results" class="hidden text-center text-on-surface-variant py-16 text-lg">No questions match your search.</p>
  </section>

  <!-- Support Section -->
  <section class="bg-surface-container-lowest py-24 border-y border-outline-variant/10" aria-labelledby="support-title">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 id="support-title" class="text-5xl font-headline font-black tracking-tight mb-4 uppercase text-on-surface">Support This Project</h2>
        <p class="text-on-surface-variant max-w-2xl mx-auto text-lg">
          ifsc.stream is an independent fan project maintained by <a href="https://www.instagram.com/nicoswd/" target="_blank" rel="noopener" class="text-primary hover:underline">@nicoswd</a>.
          Community support keeps it running and improving.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Buy me a Coffee -->
        <div class="p-10 rounded-3xl bg-surface-container flex flex-col items-center text-center group hover:bg-surface-container-high transition-all duration-500 border border-white/5">
          <div class="w-20 h-20 rounded-2xl bg-tertiary-container flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-500">
            <span class="material-symbols-outlined text-4xl text-on-tertiary-container">local_cafe</span>
          </div>
          <h3 class="text-2xl font-headline font-bold mb-4">Buy me a Coffee</h3>
          <p class="text-on-surface-variant mb-8 flex-1">Support server costs and development time for new features.</p>
          <a
            href="https://www.buymeacoffee.com/sportclimbing"
            target="_blank"
            rel="noopener"
            class="w-full py-4 bg-primary text-on-primary font-black rounded-xl hover:shadow-[0_0_20px_rgba(102,178,242,0.4)] active:scale-95 transition-all uppercase tracking-widest text-sm text-center block"
          >
            Donate Now
          </a>
        </div>
        <!-- GitHub Repo -->
        <div class="p-10 rounded-3xl bg-surface-container flex flex-col items-center text-center group hover:bg-surface-container-high transition-all duration-500 border border-white/5">
          <div class="w-20 h-20 rounded-2xl bg-outline-variant flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-500">
            <span class="material-symbols-outlined text-4xl text-on-background">code</span>
          </div>
          <h3 class="text-2xl font-headline font-bold mb-4">GitHub Repository</h3>
          <p class="text-on-surface-variant mb-8 flex-1">Explore the source, contribute to features, or fork the project.</p>
          <a
            href="https://github.com/sportclimbing/ifsc-calendar"
            target="_blank"
            rel="noopener"
            class="w-full py-4 border-2 border-outline-variant text-on-surface font-black rounded-xl hover:border-primary transition-all active:scale-95 uppercase tracking-widest text-sm text-center block"
          >
            View Source
          </a>
        </div>
        <!-- Report Issues -->
        <div class="p-10 rounded-3xl bg-surface-container flex flex-col items-center text-center group hover:bg-surface-container-high transition-all duration-500 border border-white/5">
          <div class="w-20 h-20 rounded-2xl bg-secondary-container flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-500">
            <span class="material-symbols-outlined text-4xl text-on-secondary-container">bug_report</span>
          </div>
          <h3 class="text-2xl font-headline font-bold mb-4">Report Issues</h3>
          <p class="text-on-surface-variant mb-8 flex-1">Found a bug or data discrepancy? Help us maintain accuracy.</p>
          <a
            href="https://github.com/sportclimbing/ifsc-calendar/issues"
            target="_blank"
            rel="noopener"
            class="w-full py-4 text-secondary font-black rounded-xl hover:bg-secondary/10 transition-all active:scale-95 uppercase tracking-widest text-sm text-center block"
          >
            Open Ticket
          </a>
        </div>
      </div>
    </div>
  </section>

</main>

<Modals />
<CardTemplates />

<AppFooter />
<CookieConsent />

<!-- Background Decoration -->
<div class="fixed top-0 left-0 w-full h-full pointer-events-none -z-10 overflow-hidden">
  <div class="absolute top-[-10%] left-[-5%] w-[800px] h-[800px] bg-primary/5 rounded-full blur-[150px]"></div>
  <div class="absolute bottom-[5%] right-[-10%] w-[600px] h-[600px] bg-secondary-container/5 rounded-full blur-[150px]"></div>
</div>

<script is:inline src={`/js/dayjs.min.js?v=${siteAssetVersion}`}></script>
<script is:inline src={`/js/bootstrap.min.js?v=${siteAssetVersion}`}></script>
<script is:inline src={`/js/app.js?v=${siteAssetVersion}`}></script>
<script is:inline>
  (function () {
    // Click-to-expand FAQ
    document.querySelectorAll('.faq-trigger').forEach(function (trigger) {
      trigger.addEventListener('click', function () {
        const entry = trigger.closest('.faq-entry');
        const isOpen = entry.classList.contains('is-open');
        document.querySelectorAll('.faq-entry.is-open').forEach(function (e) { e.classList.remove('is-open'); });
        if (!isOpen) entry.classList.add('is-open');
      });
    });

    // Search filter
    const input = document.getElementById('faq-search');
    const list = document.getElementById('faq-list');
    const noResults = document.getElementById('faq-no-results');
    if (!input || !list) return;
    input.addEventListener('input', function () {
      const q = input.value.trim().toLowerCase();
      const entries = list.querySelectorAll('.faq-entry');
      let visible = 0;
      entries.forEach(function (entry) {
        const match = !q || entry.textContent.toLowerCase().indexOf(q) !== -1;
        entry.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      noResults.classList.toggle('hidden', visible > 0);
    });
  })();
</script>
</body>
</html>
