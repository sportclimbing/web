---
import CardTemplates from '../../components/CardTemplates.astro';
import Footer from '../../components/Footer.astro';
import HeaderTitle from '../../components/HeaderTitle.astro';
import Modals from '../../components/Modals.astro';
import SeasonNavbar from '../../components/SeasonNavbar.astro';
import SubheaderButtons from '../../components/SubheaderButtons.astro';
import VersionUpdateNotice from '../../components/VersionUpdateNotice.astro';
import { getAllSeasons, getSeasonEventsPayload } from '../../lib/events-data';
import {
  DEFAULT_SEASON,
} from '../../lib/config';
import { siteAssetVersion } from '../../lib/site-shell';

const season = DEFAULT_SEASON;
const seasons = getAllSeasons();
const eventsPayload = getSeasonEventsPayload(season);
const events = Array.isArray(eventsPayload?.events) ? eventsPayload.events : [];
const seasonEventCount = events.length;
const seasonDisciplines = [...new Set(
  events.flatMap((event) => (Array.isArray(event?.disciplines) ? event.disciplines : []))
    .map((discipline) => String(discipline || '').trim().toLowerCase())
    .filter(Boolean),
)];
const seasonDisciplineLabel = seasonDisciplines.length
  ? seasonDisciplines.map((discipline) => `${discipline.charAt(0).toUpperCase()}${discipline.slice(1)}`).join(', ')
  : 'Boulder, Lead, and Speed';
const seasonLocations = [...new Set(
  events
    .map((event) => String(event?.location || '').trim())
    .filter(Boolean),
)];
const seasonLocationSummary = seasonLocations.slice(0, 4).join(', ');
const seasonLocationSuffix = seasonLocations.length > 4 ? ', and more.' : '.';
const faqItems = [
  {
    question: 'Where can I watch World Climbing events live?',
    answer: 'Each event card includes direct stream links for every published round, plus updates when streams go live. Please note that many broadcasts are geo-restricted; viewers outside the United States may need a VPN to access certain streams.',
  },
  {
    question: 'Can I sync this calendar with my device?',
    answer: 'Yes. Use the “Add to Calendar” option to subscribe so event updates are delivered automatically to your phone, tablet, or desktop calendar app.',
  },
  {
    question: 'Are start times shown in my local timezone?',
    answer: 'Yes. Round times and countdowns are rendered in your browser timezone so you can follow live sessions accurately.',
  },
  {
    question: 'Can I filter events by discipline, category, or competition type?',
    answer: 'Yes. Open Filters to narrow the calendar by disciplines, men/women categories, competition type, and stream availability.',
  },
  {
    question: 'Do I need to refresh the page when schedule data changes?',
    answer: 'Usually no. The page checks for new site versions every minute and shows a reload prompt when a fresh build is available.',
  },
  {
    question: 'Is this an official World Climbing website?',
    answer: 'No. This independent fan project was created and is maintained by (@nicoswd). Follow updates on Instagram at https://www.instagram.com/nicoswd/ and browse the code on GitHub at https://github.com/sportclimbing.',
    answerHtml: 'No. This independent fan project was created and is maintained by <a href="https://www.instagram.com/nicoswd/" target="_blank" rel="noopener">@nicoswd</a>. Follow updates on <a href="https://www.instagram.com/nicoswd/" target="_blank" rel="noopener">Instagram</a> and browse the code on <a href="https://github.com/sportclimbing" target="_blank" rel="noopener">GitHub</a>.',
  },
  {
    question: 'How can I support this project?',
    answer: 'You can support by buying me a coffee, starring the project on GitHub, and sharing the site with other competition climbing fans.',
  },
];
const pageTitle = `World Climbing ${season} Calendar Guide & FAQ | ifsc.stream`;
const pageDescription = `Find stream, timezone, filtering, and schedule answers for the World Climbing ${season} calendar.`;
const canonicalUrl = 'https://ifsc.stream/faq/';
const socialImageUrl = `https://ifsc.stream/img/season/${season}.svg`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <base href="/" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="preconnect" href="https://api.github.com" />
  <link rel="preconnect" href="https://calendar.ifsc.stream" />
  <link rel="preconnect" href="https://buttons.github.io" />
  <link rel="preconnect" href="https://img.youtube.com" />
  <link rel="preload" href="/fonts/montserrat-variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/rajdhani-medium.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/rajdhani-semibold.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/rajdhani-bold.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <link rel="stylesheet" href={`/css/modals.css?v=${siteAssetVersion}`} />
    <link rel="stylesheet" href={`/css/faq.css?v=${siteAssetVersion}`} />

    <script is:inline id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "tertiary-fixed": "#ffdeac",
                        "surface-container": "#1c2025",
                        "on-primary-fixed": "#001d32",
                        "on-tertiary": "#432c00",
                        "inverse-on-surface": "#2d3136",
                        "surface-container-highest": "#31353a",
                        "surface-container-lowest": "#0a0f13",
                        "on-secondary": "#680014",
                        "inverse-surface": "#e0e2e9",
                        "on-secondary-fixed-variant": "#920020",
                        "outline-variant": "#404750",
                        "surface-container-high": "#262a2f",
                        "on-tertiary-fixed-variant": "#604100",
                        "on-tertiary-fixed": "#281900",
                        "primary-fixed": "#cde5ff",
                        "tertiary": "#ffbb3d",
                        "tertiary-fixed-dim": "#ffba38",
                        "primary": "#97ccff",
                        "error-container": "#93000a",
                        "secondary-fixed": "#ffdad9",
                        "primary-fixed-dim": "#95ccff",
                        "on-error": "#690005",
                        "surface-tint": "#95ccff",
                        "on-primary": "#003352",
                        "on-surface": "#e0e2e9",
                        "secondary-fixed-dim": "#ffb3b2",
                        "on-primary-container": "#00436a",
                        "surface-bright": "#36393f",
                        "primary-container": "#66b2f2",
                        "error": "#ffb4ab",
                        "surface-dim": "#101418",
                        "inverse-primary": "#00639a",
                        "background": "#101418",
                        "on-background": "#e0e2e9",
                        "on-secondary-container": "#ffa8a8",
                        "secondary": "#ffb3b2",
                        "on-error-container": "#ffdad6",
                        "on-primary-fixed-variant": "#004a75",
                        "surface-container-low": "#181c21",
                        "outline": "#8a919b",
                        "on-surface-variant": "#c0c7d1",
                        "tertiary-container": "#e39f00",
                        "on-secondary-fixed": "#410009",
                        "surface-variant": "#31353a",
                        "secondary-container": "#9f0224",
                        "surface": "#101418",
                        "on-tertiary-container": "#573b00"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Space Grotesk"],
                        "body": ["Plus Jakarta Sans"],
                        "label": ["Space Grotesk"]
                    }
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #101418; color: #e0e2e9; }
        .font-headline { font-family: 'Space Grotesk', sans-serif; }
        .glass-panel { background: rgba(16, 20, 24, 0.7); backdrop-filter: blur(20px); }
        .kinetic-gradient { background: linear-gradient(135deg, #97CCFF 0%, #66B2F2 100%); }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #101418; }
        ::-webkit-scrollbar-thumb { background: #31353a; border-radius: 4px; }
    </style>

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="ifsc.stream" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:image" content={socialImageUrl} />
  <meta property="og:image:alt" content={`World Climbing ${season} season calendar preview`} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={socialImageUrl} />
  <meta name="twitter:image:alt" content={`World Climbing ${season} season calendar preview`} />

  <script type="application/ld+json" id="structured-data-organization">
      {
          "@context": "https://schema.org",
          "@type": "Organization",
          "@id": "https://ifsc.stream/#organization",
          "name": "ifsc.stream",
          "url": "https://ifsc.stream/",
          "logo": "https://ifsc.stream/img/logo.png",
          "sameAs": [
              "https://github.com/sportclimbing/ifsc-calendar",
              "https://www.instagram.com/nicoswd/"
          ]
      }
  </script>
  <script
    type="application/ld+json"
    id="structured-data-faq"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    })}
  ></script>
  <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon.png" id="favicon" />
</head>
<body class="bg-background text-on-background min-h-screen" data-page-type="faq" data-build-version={siteAssetVersion}>
<VersionUpdateNotice />
<CardTemplates />

<div id="ifsc-season">
  <HeaderTitle season={season} homeUrl="/" />
</div>

<SeasonNavbar />

<main role="main">
  <section class="season-seo-content" aria-labelledby="season-seo-title">
    <h1 id="season-seo-title">World Climbing {season} Calendar Guide</h1>
    <p>
      The {season} World Climbing calendar currently lists {seasonEventCount} events across {seasonDisciplineLabel}.
      Track livestream rounds, and results updates in one place.
    </p>
    <p>
      Main host locations include {seasonLocationSummary || 'multiple international venues'}{seasonLocationSuffix}
    </p>
    <div class="season-seo-faq">
      <h2>FAQ</h2>
      {faqItems.map((item) => (
        <>
          <h3>{item.question}</h3>
          <p set:html={item.answerHtml || item.answer}></p>
        </>
      ))}
    </div>
  </section>

  <section class="season-seo-content" aria-labelledby="support-title">
    <h2 id="support-title">Support This Project</h2>
    <p>
      This site is maintained independently by <a href="https://www.instagram.com/nicoswd/" target="_blank" rel="noopener">@nicoswd</a> and community support keeps it running and improving.
    </p>
    <h3>1. Buy me a coffee</h3>
    <p>
      Help cover maintenance costs:
      <a href="https://www.buymeacoffee.com/sportclimbing" target="_blank" rel="noopener">buymeacoffee.com/sportclimbing</a>
    </p>
    <h3>2. Star the repository</h3>
    <p>
      A star on GitHub helps more climbers discover the project:
      <a href="https://github.com/sportclimbing/ifsc-calendar" target="_blank" rel="noopener">github.com/sportclimbing/ifsc-calendar</a>
    </p>
    <h3>3. Share and report issues</h3>
    <p>
      Share the site with other fans and report problems or ideas:
      <a href="https://github.com/sportclimbing/ifsc-calendar/issues" target="_blank" rel="noopener">github.com/sportclimbing/ifsc-calendar/issues</a>
    </p>
  </section>
</main>

<Modals />

<Footer
  seasons={seasons}
  selectedSeason={season}
  buildVersion={siteAssetVersion}
/>

<script is:inline src={`/js/dayjs.min.js?v=${siteAssetVersion}`}></script>
<script is:inline src={`/js/bootstrap.min.js?v=${siteAssetVersion}`}></script>
<script is:inline src={`/js/app.js?v=${siteAssetVersion}`}></script>
</body>
</html>
