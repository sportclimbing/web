---
import { siteAssetVersion } from '../lib/site-shell';
import AppHeader from './AppHeader.astro';
import AppFooter from './AppFooter.astro';
import EventCards from './EventCards.astro';
import Modals from './Modals.astro';
import VideoModal from './VideoModal.astro';
import CardTemplates from './CardTemplates.astro';
import HeroSection from './HeroSection.astro';
import {
  DEFAULT_SEASON,
  HERO_BG_OVERRIDES,
} from '../lib/config';
import { getSeasonEventsPayload } from '../lib/events-data';

const {
  season,
  seasons,
  event,
  relatedLinks = {},
  canonicalPath,
  pageTitle,
  pageDescription,
  socialImagePath = '/img/logo.png',
  socialImageAlt = 'ifsc.stream event preview',
} = Astro.props;

const normalizedSeason = String(season);
const normalizedSeasons = Array.isArray(seasons) ? seasons.map(String) : [];
const canonicalUrl = `https://ifsc.stream${canonicalPath}`;
const normalizedEventId = String(event.id)
const eventName = String(event?.name || '').trim() || 'Event';
const seasonHomePath = normalizedSeason === DEFAULT_SEASON ? '/' : `/season/${normalizedSeason}/`;
const seasonPagePath = `/season/${normalizedSeason}/`;

// Hero section logic
const rounds = Array.isArray(event.rounds) ? event.rounds : [];
const now = new Date();
let liveRound = null;
let nextRound = null;

for (const round of rounds) {
    const startsAt = new Date(round.starts_at);
    const endsAt = new Date(round.ends_at);
    if (now >= startsAt && now <= endsAt) {
        liveRound = round;
        break;
    }
    if (startsAt > now) {
        if (!nextRound || startsAt < new Date(nextRound.starts_at)) {
            nextRound = round;
        }
    }
}

const heroRound = liveRound || nextRound || rounds[rounds.length - 1];
const isLive = Boolean(liveRound);
const heroRoundName = heroRound?.name || '';
const heroEventTitle = eventName;

const youtube_video_id_from_url = (url) => {
    if (!url) return null;
    const matches = String(url).match(
        /(?:youtu\.be\/|youtube(?:-nocookie)?\.com\/(?:watch\?(?:.*&)?v=|live\/|embed\/|shorts\/))(?<video_id>[A-Za-z0-9_-]{10,})/i,
    );
    return matches?.groups?.video_id || null;
};

const firstStreamRound = rounds.find((r) => r.stream_url && youtube_video_id_from_url(r.stream_url));
const heroYouTubeVideoId = firstStreamRound ? youtube_video_id_from_url(firstStreamRound.stream_url) : null;
const seasonOverride = HERO_BG_OVERRIDES[normalizedSeason] || {};
const resolvedBgVideoId = seasonOverride.youTubeVideoId ?? heroYouTubeVideoId;
const heroBgImage = resolvedBgVideoId
    ? `https://img.youtube.com/vi/${resolvedBgVideoId}/maxresdefault.jpg`
    : '/img/hero/hero-bg.jpg';
const heroBgPosition = seasonOverride.backgroundPosition ?? 'center 30%';

const updatedAt = getSeasonEventsPayload(season)?.metadata?.updated_at || undefined;
const previousEventLink = relatedLinks?.previousEvent || null;
const nextEventLink = relatedLinks?.nextEvent || null;
const sameSeasonEventLinks = Array.isArray(relatedLinks?.sameSeasonEvents) ? relatedLinks.sameSeasonEvents : [];
const sameDisciplineEventLinks = Array.isArray(relatedLinks?.sameDisciplineEvents) ? relatedLinks.sameDisciplineEvents : [];
const hasRelatedEventLinks = Boolean(
  previousEventLink
  || nextEventLink
  || sameSeasonEventLinks.length
  || sameDisciplineEventLinks.length,
);
const socialImageUrl = socialImagePath.startsWith('http')
  ? socialImagePath
  : `https://ifsc.stream${socialImagePath}`;
const breadcrumbStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://ifsc.stream/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: `Season ${normalizedSeason}`,
      item: `https://ifsc.stream${seasonPagePath}`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: eventName,
      item: canonicalUrl,
    },
  ],
};
---
<!doctype html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <base href="/" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://api.github.com" />
    <link rel="preconnect" href="https://calendar.ifsc.stream" />
    <link rel="preconnect" href="https://buttons.github.io" />
    <link rel="preconnect" href="https://img.youtube.com" />

    <script is:inline src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <link rel="stylesheet" href={`/css/modals.css?v=${siteAssetVersion}`} />

    <script is:inline id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "tertiary-fixed": "#ffdeac",
                        "surface-container": "#1c2025",
                        "on-primary-fixed": "#001d32",
                        "on-tertiary": "#432c00",
                        "inverse-on-surface": "#2d3136",
                        "surface-container-highest": "#31353a",
                        "surface-container-lowest": "#0a0f13",
                        "on-secondary": "#680014",
                        "inverse-surface": "#e0e2e9",
                        "on-secondary-fixed-variant": "#920020",
                        "outline-variant": "#404750",
                        "surface-container-high": "#262a2f",
                        "on-tertiary-fixed-variant": "#604100",
                        "on-tertiary-fixed": "#281900",
                        "primary-fixed": "#cde5ff",
                        "tertiary": "#ffbb3d",
                        "tertiary-fixed-dim": "#ffba38",
                        "primary": "#97ccff",
                        "error-container": "#93000a",
                        "secondary-fixed": "#ffdad9",
                        "primary-fixed-dim": "#95ccff",
                        "on-error": "#690005",
                        "surface-tint": "#95ccff",
                        "on-primary": "#003352",
                        "on-surface": "#e0e2e9",
                        "secondary-fixed-dim": "#ffb3b2",
                        "on-primary-container": "#00436a",
                        "surface-bright": "#36393f",
                        "primary-container": "#66b2f2",
                        "error": "#ffb4ab",
                        "surface-dim": "#101418",
                        "inverse-primary": "#00639a",
                        "background": "#101418",
                        "on-background": "#e0e2e9",
                        "on-secondary-container": "#ffa8a8",
                        "secondary": "#ffb3b2",
                        "on-error-container": "#ffdad6",
                        "on-primary-fixed-variant": "#004a75",
                        "surface-container-low": "#181c21",
                        "outline": "#8a919b",
                        "on-surface-variant": "#c0c7d1",
                        "tertiary-container": "#e39f00",
                        "on-secondary-fixed": "#410009",
                        "surface-variant": "#31353a",
                        "secondary-container": "#9f0224",
                        "surface": "#101418",
                        "on-tertiary-container": "#573b00"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Space Grotesk"],
                        "body": ["Plus Jakarta Sans"],
                        "label": ["Space Grotesk"]
                    }
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #101418; color: #e0e2e9; }
        .font-headline { font-family: 'Space Grotesk', sans-serif; }
        .glass-panel { background: rgba(16, 20, 24, 0.7); backdrop-filter: blur(20px); }
        .kinetic-gradient { background: linear-gradient(135deg, #97CCFF 0%, #66B2F2 100%); }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #101418; }
        ::-webkit-scrollbar-thumb { background: #31353a; border-radius: 4px; }
    </style>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="ifsc.stream" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={socialImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <script type="application/ld+json" id="structured-data-organization">
        {
            "@context": "https://schema.org",
            "@type": "Organization",
            "@id": "https://ifsc.stream/#organization",
            "name": "ifsc.stream",
            "url": "https://ifsc.stream/",
            "logo": "https://ifsc.stream/img/logo.png",
            "sameAs": [
                "https://github.com/sportclimbing/ifsc-calendar",
                "https://www.instagram.com/nicoswd/"
            ]
        }
    </script>
    <script
      type="application/ld+json"
      id="structured-data-breadcrumbs"
      set:html={JSON.stringify(breadcrumbStructuredData)}
    ></script>
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon.png" id="favicon" />
</head>
<body class="bg-background text-on-background min-h-screen" data-page-type="event" data-event-id={normalizedEventId || undefined} data-build-version={siteAssetVersion} data-updated-at={updatedAt}>

<AppHeader />

<main role="main">
    <!-- Hero Section -->
    <HeroSection
        heroEventTitle={heroEventTitle}
        isLive={isLive}
        heroRound={heroRound}
        heroRoundName={heroRoundName}
        leagueName={event?.league_name}
        heroBgImage={heroBgImage}
        heroBgPosition={heroBgPosition}
    />

    <div class="max-w-screen-2xl mx-auto px-6 pt-16 flex gap-12 relative" id="accordion">
        <div class="flex-1 pb-24">
            <!-- Breadcrumbs -->
            <nav class="mb-12" aria-label="Breadcrumb">
                <div class="bg-surface-container-low p-2 rounded-xl flex items-center gap-2 overflow-x-auto no-scrollbar">
                    <div class="flex items-center gap-2 p-1 bg-surface-container-lowest rounded-lg whitespace-nowrap">
                        <a href="/" class="px-6 py-2 text-on-surface-variant hover:text-on-surface transition-colors uppercase text-xs tracking-widest font-bold">Home</a>
                        <div class="h-4 w-px bg-outline-variant mx-1"></div>
                        <a href={seasonPagePath} class="px-6 py-2 text-on-surface-variant hover:text-on-surface transition-colors uppercase text-xs tracking-widest font-bold">{normalizedSeason} Season</a>
                        <div class="h-4 w-px bg-outline-variant mx-1"></div>
                        <span class="px-6 py-2 bg-primary text-on-primary font-bold rounded-lg uppercase text-xs tracking-widest">{eventName}</span>
                    </div>
                </div>
            </nav>

            <section>
                <div class="grid grid-cols-1 gap-12">
                    <EventCards
                      events={[event]}
                      expandAllRounds={true}
                      hideRoundCollapseControls={true}
                      showNoResultsMessage={false}
                    />
                </div>
            </section>

            {hasRelatedEventLinks ? (
              <section class="mt-20 border-t border-outline-variant/20 pt-20" aria-labelledby="event-internal-links-title">
                <h2 id="event-internal-links-title" class="text-3xl font-black font-headline uppercase mb-12 tracking-tight">Related Events</h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                    {previousEventLink || nextEventLink ? (
                      <div class="flex flex-col gap-6">
                        <h3 class="text-on-surface-variant uppercase text-xs font-bold tracking-[0.2em]">Sequence</h3>
                        <div class="flex flex-col gap-4">
                            {previousEventLink && (
                              <a class="group flex items-center justify-between p-6 bg-surface-container-low rounded-xl border border-outline-variant/10 hover:border-primary/50 transition-all" href={previousEventLink.href}>
                                <div class="flex flex-col gap-1">
                                    <span class="text-[10px] uppercase tracking-widest text-primary font-bold">Previous Event</span>
                                    <span class="text-lg font-headline font-bold uppercase">{previousEventLink.label}</span>
                                </div>
                                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">arrow_back</span>
                              </a>
                            )}
                            {nextEventLink && (
                              <a class="group flex items-center justify-between p-6 bg-surface-container-low rounded-xl border border-outline-variant/10 hover:border-primary/50 transition-all" href={nextEventLink.href}>
                                <div class="flex flex-col gap-1">
                                    <span class="text-[10px] uppercase tracking-widest text-primary font-bold">Next Event</span>
                                    <span class="text-lg font-headline font-bold uppercase">{nextEventLink.label}</span>
                                </div>
                                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">arrow_forward</span>
                              </a>
                            )}
                        </div>
                      </div>
                    ) : null}

                    {sameSeasonEventLinks.length ? (
                      <div class="flex flex-col gap-6">
                        <h3 class="text-on-surface-variant uppercase text-xs font-bold tracking-[0.2em]">Season {normalizedSeason}</h3>
                        <div class="grid grid-cols-1 gap-3">
                          {sameSeasonEventLinks.map((link) => (
                            <a class="text-on-surface hover:text-primary transition-colors py-2 flex items-center gap-3 group" href={link.href}>
                                <span class="w-1.5 h-1.5 rounded-full bg-primary/30 group-hover:bg-primary transition-colors"></span>
                                {link.label}
                            </a>
                          ))}
                        </div>
                      </div>
                    ) : null}

                    {sameDisciplineEventLinks.length ? (
                      <div class="flex flex-col gap-6">
                        <h3 class="text-on-surface-variant uppercase text-xs font-bold tracking-[0.2em]">Similar Disciplines</h3>
                        <div class="grid grid-cols-1 gap-3">
                          {sameDisciplineEventLinks.map((link) => (
                            <a class="text-on-surface hover:text-primary transition-colors py-2 flex items-center gap-3 group" href={link.href}>
                                <span class="w-1.5 h-1.5 rounded-full bg-primary/30 group-hover:bg-primary transition-colors"></span>
                                {link.label}
                            </a>
                          ))}
                        </div>
                      </div>
                    ) : null}
                </div>
              </section>
            ) : null}
        </div>
    </div>

    <!-- Dynamic Ticker / Newsletter -->
    <section class="bg-surface-container-lowest border-y border-outline-variant/15 py-20">
        <div class="max-w-screen-2xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-12">
            <div class="max-w-xl">
                <h3 class="text-4xl font-black font-headline uppercase leading-tight">Never Miss a Finals Session</h3>
                <p class="text-on-surface-variant text-lg mt-4">Get real-time alerts for live streams, athlete results, and final boulder rankings directly to your inbox.</p>
            </div>
            <div class="flex w-full md:w-auto gap-3">
                <input class="bg-surface-container-low border-outline-variant focus:ring-primary focus:border-primary rounded-xl px-8 py-5 text-base w-full md:w-96" placeholder="YOUR EMAIL ADDRESS" type="email"/>
                <button class="kinetic-gradient text-on-primary-fixed px-10 py-5 rounded-xl font-bold uppercase text-sm tracking-widest whitespace-nowrap shadow-lg hover:shadow-primary/20 transition-all">Subscribe</button>
            </div>
        </div>
    </section>
</main>

<Modals />
<VideoModal />
<CardTemplates />

<AppFooter />

<script is:inline src={`/js/dayjs.min.js?v=${siteAssetVersion}`}></script>
<script is:inline src={`/js/bootstrap.min.js?v=${siteAssetVersion}`}></script>
<script is:inline src={`/js/app.js?v=${siteAssetVersion}`}></script>
</body>
</html>
