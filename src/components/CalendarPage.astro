---
import { siteAssetVersion } from '../lib/site-shell';
import CardTemplates from './CardTemplates.astro';
import EventCards from './EventCards.astro';
import Footer from './Footer.astro';
import HeaderTitle from './HeaderTitle.astro';
import Modals from './Modals.astro';
import SeasonNavbar from './SeasonNavbar.astro';

const {
  season,
  seasons,
  eventsPayload,
  canonicalPath,
  pageTitle,
  pageDescription,
} = Astro.props;

const normalizedSeason = String(season);
const normalizedSeasons = Array.isArray(seasons) ? seasons.map(String) : [];
const events = Array.isArray(eventsPayload?.events) ? eventsPayload.events : [];
const canonicalUrl = `https://ifsc.stream${canonicalPath}`;
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <base href="/" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="ifsc.stream" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content="https://ifsc.stream/img/logo.png" />
    <meta property="og:image:alt" content="ifsc.stream logo" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content="https://ifsc.stream/img/logo.png" />

    <script type="application/ld+json" id="structured-data-organization">
        {
            "@context": "https://schema.org",
            "@type": "Organization",
            "@id": "https://ifsc.stream/#organization",
            "name": "ifsc.stream",
            "url": "https://ifsc.stream/",
            "logo": "https://ifsc.stream/img/logo.png",
            "sameAs": [
                "https://github.com/sportclimbing/ifsc-calendar",
                "https://www.instagram.com/nicoswd/"
            ]
        }
    </script>
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon.png" id="favicon" />
    <link rel="preload" as="font" href="/fonts/JTUSjIg1_i6t8kCHKm459Wlhyw.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/LDI2apCSOBg7S-QT7pb0EPOreec.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/LDI2apCSOBg7S-QT7pbYF_Oreec.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/LDI2apCSOBg7S-QT7pa8FvOreec.woff2" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/css/fonts-local.css" />
    <link rel="stylesheet" href="/css/calendar.css" />
    <link rel="stylesheet" href="/css/calendar-desktop.css" media="screen and (min-width: 501px)" />
    <link rel="stylesheet" href="/css/calendar-mobile.css" media="screen and (max-width: 500px)" />
</head>
<body>
<CardTemplates />

<div id="ifsc-season">
    <HeaderTitle season={normalizedSeason} homeUrl={canonicalPath} />
</div>

<SeasonNavbar />

<section class="subheader-buttons">
    <div class="subheader-controls">
        <div class="season-control">
            <label class="season-label" for="season-selector">Season</label>
            <select id="season-selector" name="season-selector" class="btn btn-primary season-selector">
              {normalizedSeasons.map((seasonOption) => (
                <option value={seasonOption} selected={seasonOption === normalizedSeason}>
                  {seasonOption}
                </option>
              ))}
            </select>
        </div>
        <button class="btn btn-primary filters-button" data-bs-toggle="modal" data-bs-target="#filter-modal">🔍 Filters</button>
    </div>
</section>

<nav class="season-month-nav" id="season-month-nav" aria-label="Jump to month">
    <ul class="season-month-nav-list">
        <li><button type="button" class="season-month-nav-link" data-month-index="0">January</button></li>
        <li><button type="button" class="season-month-nav-link" data-month-index="1">February</button></li>
        <li><button type="button" class="season-month-nav-link" data-month-index="2">March</button></li>
        <li><button type="button" class="season-month-nav-link" data-month-index="3">April</button></li>
        <li><button type="button" class="season-month-nav-link" data-month-index="4">May</button></li>
        <li><button type="button" class="season-month-nav-link" data-month-index="5">June</button></li>
        <li><button type="button" class="season-month-nav-link" data-month-index="6">July</button></li>
        <li><button type="button" class="season-month-nav-link" data-month-index="7">August</button></li>
        <li><button type="button" class="season-month-nav-link" data-month-index="8">September</button></li>
        <li><button type="button" class="season-month-nav-link" data-month-index="9">October</button></li>
        <li><button type="button" class="season-month-nav-link" data-month-index="10">November</button></li>
        <li><button type="button" class="season-month-nav-link" data-month-index="11">December</button></li>
    </ul>
</nav>

<main role="main">
    <hr class="next-event-divider" id="next-event-divider-top" aria-hidden="true" />
    <div class="next-event">
        <h1 id="next-event-title"></h1>
        <div class="event-not-started-countdown" id="next-event-countdown" aria-live="polite" aria-atomic="true" hidden>
            <div class="event-not-started-countdown-grid">
                <div class="event-not-started-countdown-chip">
                    <span class="event-not-started-countdown-value" id="next-event-countdown-days">0</span>
                    <span class="event-not-started-countdown-unit">Days</span>
                </div>
                <div class="event-not-started-countdown-chip">
                    <span class="event-not-started-countdown-value" id="next-event-countdown-hours">00</span>
                    <span class="event-not-started-countdown-unit">Hours</span>
                </div>
                <div class="event-not-started-countdown-chip">
                    <span class="event-not-started-countdown-value" id="next-event-countdown-minutes">00</span>
                    <span class="event-not-started-countdown-unit">Minutes</span>
                </div>
            </div>
        </div>
        <div id="next-event-details"></div>
    </div>
    <hr class="next-event-divider" id="next-event-divider" aria-hidden="true" />
    <div id="accordion">
      <EventCards events={events} />
    </div>
</main>

<Modals />

<Footer
    seasons={normalizedSeasons}
    selectedSeason={normalizedSeason}
    buildVersion={siteAssetVersion}
/>

<script src={`/js/dayjs.min.js?v=${siteAssetVersion}`}></script>
<script src={`/js/bootstrap.min.js?v=${siteAssetVersion}`}></script>
<script src={`/js/app.js?v=${siteAssetVersion}`}></script>
</body>
</html>
