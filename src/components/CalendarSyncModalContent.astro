---
import { DEFAULT_SEASON } from '../lib/config.js';

const allEventsFiles = import.meta.glob('../../events/events_*.json', { eager: true }) as Record<string, { metadata: { updated_at: string } }>;
const eventsData = allEventsFiles[`../../events/events_${DEFAULT_SEASON}.json`];

const updatedAt = new Date(eventsData.metadata.updated_at).toLocaleString(undefined, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
});
---
<style>
    .kinetic-gradient {
        background: linear-gradient(135deg, #97CCFF 0%, #66B2F2 100%);
    }
</style>
<div class="modal-dialog max-w-6xl mx-auto my-10">
    <div class="modal-content bg-surface/80 backdrop-blur-xl w-full rounded-xl overflow-hidden border border-outline-variant/15 shadow-2xl flex flex-col" style="max-width: 800px">
        <!-- Header Section -->
        <div class="px-8 pt-10 pb-8 text-center">
            <div class="flex justify-center mb-4">
                <div class="w-12 h-1 bg-primary rounded-full"></div>
            </div>
            <h1 class="font-headline text-4xl font-bold tracking-tighter uppercase text-primary" id="calendar-modal-title">CALENDAR SYNC</h1>
            <p class="font-body text-on-surface-variant mt-3 max-w-lg mx-auto leading-relaxed">
                Stay updated with every boulder, lead, and speed final. Sync the official World Climbing schedule directly to your personal device.
            </p>
        </div>
        <!-- Three-Card Layout -->
        <div class="px-8 grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <!-- Google Calendar -->
            <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 flex flex-col items-center text-center group hover:bg-surface-container-high transition-all duration-300">
                <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-primary text-3xl">calendar_today</span>
                </div>
                <h3 class="font-headline font-bold text-lg mb-2 text-on-surface">Google Calendar</h3>
                <p class="text-xs text-on-surface-variant font-medium mb-8 leading-tight">One-click sync for cloud-based tracking across all devices.</p>
                <a class="mt-auto w-full py-3 kinetic-gradient text-on-primary-container font-headline font-bold text-sm rounded-lg hover:opacity-90 transition-opacity uppercase tracking-wider text-center block" href="https://www.google.com/calendar/render?cid=webcal://calendar.ifsc.stream" target="_blank" rel="noopener">
                    Connect Now
                </a>
            </div>
            <!-- Mobile & Desktop -->
            <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 flex flex-col items-center text-center group hover:bg-surface-container-high transition-all duration-300">
                <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-primary text-3xl">devices</span>
                </div>
                <h3 class="font-headline font-bold text-lg mb-2 text-on-surface">Apple &amp; Outlook</h3>
                <p class="text-xs text-on-surface-variant font-medium mb-8 leading-tight">Native integration for iOS, macOS, and Windows calendars.</p>
                <a class="mt-auto w-full py-3 kinetic-gradient text-on-primary-container font-headline font-bold text-sm rounded-lg hover:opacity-90 transition-opacity uppercase tracking-wider text-center block" href="webcal://calendar.ifsc.stream" rel="noopener">
                    Sync Device
                </a>
            </div>
            <!-- Static Download -->
            <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 flex flex-col items-center text-center group hover:bg-surface-container-high transition-all duration-300">
                <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-primary text-3xl">download</span>
                </div>
                <h3 class="font-headline font-bold text-lg mb-2 text-on-surface">Static File</h3>
                <p class="text-xs text-on-surface-variant font-medium mb-8 leading-tight">Download <code>.ics</code> file for manual import and offline viewing.</p>
                <div class="mt-auto flex flex-col gap-3 w-full">
                    <a class="w-full py-3 border-2 border-primary/30 text-primary font-headline font-bold text-sm rounded-lg hover:bg-primary/10 transition-all uppercase tracking-wider text-center block" href="https://calendar.ifsc.stream" target="_blank" rel="noopener">
                        Download .ICS
                    </a>
                    <a class="w-full py-2 text-on-surface-variant font-headline font-bold text-xs rounded-lg hover:text-primary transition-colors uppercase tracking-wider text-center block" href="https://github.com/sportclimbing/ifsc-calendar/wiki" target="_blank" rel="noopener">
                        View Tutorial
                    </a>
                </div>
            </div>
        </div>
        <!-- Footer -->
        <div class="bg-surface-container-highest/30 px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-4 border-t border-outline-variant/10">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-surface-container flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-tertiary">sync</span>
                </div>
                <div>
                    <h4 class="font-headline font-bold text-sm uppercase tracking-tight text-on-surface">Auto-Update Schedule</h4>
                    <p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant mt-0.5">
                        <span class="inline-block w-1.5 h-1.5 rounded-full bg-primary animate-pulse mr-1"></span>
                        Last updated at {updatedAt}
                    </p>
                </div>
            </div>
            <button type="button" class="text-on-surface-variant hover:text-on-surface transition-colors font-label text-xs uppercase tracking-widest font-bold px-6 py-2 rounded-lg hover:bg-surface-container transition-colors shrink-0" data-bs-dismiss="modal">
                Close
            </button>
        </div>
    </div>
</div>
