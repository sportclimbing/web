---
import { DEFAULT_SEASON } from '../lib/config';

const { seasons = [], selectedSeason = '', buildVersion = 'astro' } = Astro.props;

const normalizedSelectedSeason = String(selectedSeason || '');
const sortedSeasons = [...(Array.isArray(seasons) ? seasons : [])]
  .map((season) => String(season))
  .sort((a, b) => Number(a) - Number(b));
const currentYear = String(new Date().getFullYear());
const season_href = (season) => (season === DEFAULT_SEASON ? '/' : `/season/${season}/`);
---
<footer>
  <div class="footer-content">
    <div class="footer-copy">
      <p class="footer-seasons">
        <span class="footer-seasons-nav" id="footer-seasons-nav" aria-label="Season links">
          {sortedSeasons.map((season) => {
            const isActive = season === normalizedSelectedSeason;

            return (
              <a
                class:list={['footer-season-link', { 'is-active': isActive }]}
                href={season_href(season)}
                aria-current={isActive ? 'page' : undefined}
              >
                {season}
              </a>
            );
          })}
        </span>
      </p>
      <p class="footer-credits">&copy; <span id="footer-copyright-year">{currentYear}</span> by <a href="https://nico.es/">@nicoswd</a> (<a href="https://github.com/sportclimbing" target="_blank" rel="noopener">@sportclimbing</a>) - <a href="https://www.reddit.com/r/CompetitionClimbing/comments/13bj7vx/i_made_a_better_ifsc_competition_calendar_you_can/" target="_blank" rel="noopener">Discuss on Reddit</a> </p>
      <p class="footer-disclaimer">In no way affiliated with, or endorsed by <a href="https://www.worldclimbing.com/" target="_blank" rel="noopener">WoRLd CLiMbiNg</a></p>
    </div>

    <div class="footer-actions">
      <button type="button" class="ifsc-action-button ifsc-action-button-primary footer-theme-toggle footer-action-tooltip" id="theme-toggle">
        ◐ System Mode
      </button>
    </div>
    <div class="footer-meta">
      <table class="footer-meta-table" aria-label="Footer metadata">
        <tbody>
          <tr>
            <th scope="row">timezone</th>
            <td class="footer-meta-sep">:</td>
            <td><span class="footer-meta-value" id="footer-timezone-name">Europe/Madrid</span></td>
          </tr>
          <tr>
            <th scope="row">build</th>
            <td class="footer-meta-sep">:</td>
            <td><span class="footer-meta-value footer-build-value">{buildVersion}</span></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</footer>
