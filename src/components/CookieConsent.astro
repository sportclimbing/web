<!-- Default consent: analytics denied until user chooses -->
<div
        id="cookie-consent"
        class="fixed bottom-4 right-4 z-50 w-full max-w-[420px] px-4 sm:px-0"
        style="display:none!important"
        role="dialog"
        aria-modal="true"
        aria-labelledby="cookie-consent-title"
        aria-describedby="cookie-consent-description"
>
    <div class="bg-surface-container/90 backdrop-blur-2xl rounded-xl shadow-[0_-12px_32px_-4px_rgba(0,0,0,0.4)] border-t border-white/5 ring-1 ring-white/10 p-6">
        <div class="flex gap-4 items-start">
            <div class="flex-shrink-0 pt-1">
                <span class="material-symbols-outlined text-primary leading-none text-2xl">cookie</span>
            </div>

            <div class="min-w-0">
                <h2 id="cookie-consent-title" class="text-on-surface font-headline font-bold text-base">
                    Cookie Preferences
                </h2>
                <p id="cookie-consent-description" class="text-on-surface-variant leading-relaxed mt-2 text-sm">
                    We use optional analytics cookies to measure traffic and improve the site.
                    You can accept or reject them at any time. See our
                    <a href="/privacy-policy/" class="underline font-semibold">Privacy Policy</a>
                    for more information.
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-6">
            <button
                    id="cookie-accept"
                    type="button"
                    class="w-full bg-primary-container text-on-primary-fixed font-headline font-bold uppercase tracking-wider py-2.5 rounded-lg hover:scale-[0.98] transition-all active:opacity-80 text-sm"
            >
                Accept
            </button>

            <button
                    id="cookie-reject"
                    type="button"
                    class="w-full bg-surface-container-high text-on-surface font-headline font-bold uppercase tracking-wider py-2.5 rounded-lg hover:scale-[0.98] transition-all active:opacity-80 border border-outline-variant/20 text-sm"
            >
                Reject
            </button>
        </div>
    </div>
</div>
