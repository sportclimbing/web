---
---
<footer class="bg-background w-full py-16 border-t border-primary/10">
    <div class="max-w-screen-2xl mx-auto px-8 flex flex-col md:flex-row justify-between items-center gap-10">
        <div class="flex flex-col items-center md:items-start gap-4">
            <div class="text-primary font-headline font-black text-2xl tracking-tighter uppercase">World Climbing Calendar</div>
            <p class="text-on-surface-variant font-headline text-[0.6rem] tracking-[0.15em] opacity-75">
                Copyright &copy; {new Date().getFullYear()} <a href="https://nico.es/">@nicoSWD</a>.<br />
                In no way affiliated with, or endorsed by <a href="https://www.worldclimbing.com/">WoRLd CLiMbiNg</a><br />
                <button
                        id="open-cookie-settings"
                        type="button"
                        class="z-40 text-[0.6rem] underline text-on-surface-variant mt-1 block"
                >Cookie Settings</button>
            </p>
        </div>
        <div class="flex flex-wrap justify-center items-center gap-10">
            <a class="text-on-surface-variant hover:text-primary transition-colors font-['Plus_Jakarta_Sans'] text-xs uppercase tracking-widest" href="/privacy-policy/">Privacy Policy</a>
            <a class="text-on-surface-variant hover:text-primary transition-colors font-['Plus_Jakarta_Sans'] text-xs uppercase tracking-widest" href="/faq/">FAQ</a>
            <button
                id="theme-toggle"
                type="button"
                class="hidden text-on-surface-variant hover:text-primary transition-colors flex items-center gap-1.5"
                aria-label="Switch to light mode"
                aria-pressed="false"
            >
                <span class="material-symbols-outlined theme-toggle-icon" style="font-size: 18px;">light_mode</span>
            </button>
        </div>
        <div class="flex gap-6">
            <a href="https://nico.es" target="_blank" rel="noopener"><span class="material-symbols-outlined text-on-surface-variant hover:text-primary cursor-pointer" style="font-size: 28px; width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center; position: relative; top: -1px;">public</span></a>
            <a href="https://github.com/sportclimbing" target="_blank" rel="noopener" aria-label="GitHub"><span class="github-icon inline-block cursor-pointer" style="width:24px;height:24px;"></span></a>
        </div>
    </div>
</footer>
