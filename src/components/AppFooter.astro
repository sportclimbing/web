<footer class="bg-[#101418] w-full py-16 border-t border-[#97CCFF]/10">
    <div class="max-w-screen-2xl mx-auto px-8 flex flex-col md:flex-row justify-between items-center gap-10">
        <div class="flex flex-col items-center md:items-start gap-4">
            <div class="text-[#97CCFF] font-headline font-black text-2xl tracking-tighter uppercase">IFSC KINETIC</div>
            <p class="text-[#C0C7D1] font-['Plus_Jakarta_Sans'] text-xs uppercase tracking-[0.2em] opacity-60">
                © {new Date().getFullYear()} INTERNATIONAL FEDERATION OF SPORT CLIMBING
            </p>
        </div>
        <div class="flex flex-wrap justify-center gap-10">
            <a class="text-[#C0C7D1] hover:text-primary transition-colors font-['Plus_Jakarta_Sans'] text-xs uppercase tracking-widest" href="#">Privacy Policy</a>
            <a class="text-[#C0C7D1] hover:text-primary transition-colors font-['Plus_Jakarta_Sans'] text-xs uppercase tracking-widest" href="#">Terms of Service</a>
            <a class="text-[#C0C7D1] hover:text-primary transition-colors font-['Plus_Jakarta_Sans'] text-xs uppercase tracking-widest" href="#">Press</a>
            <a class="text-[#C0C7D1] hover:text-primary transition-colors font-['Plus_Jakarta_Sans'] text-xs uppercase tracking-widest" href="#">Contact</a>
        </div>
        <div class="flex gap-6">
            <span class="material-symbols-outlined text-[#C0C7D1] hover:text-[#97CCFF] cursor-pointer text-2xl">public</span>
            <span class="material-symbols-outlined text-[#C0C7D1] hover:text-[#97CCFF] cursor-pointer text-2xl">smart_display</span>
        </div>
    </div>
</footer>