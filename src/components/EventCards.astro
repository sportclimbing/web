---
import { build_start_list_modal_url } from '../lib/start-list-modal-fragments';
import { build_event_page_path } from '../lib/event-pages';
import { athlete_photo_local_sources_build, video_id_from_stream } from '../lib/shared/media.js';
import { round_will_be_streamed } from '../js/app/helpers/core.js';

const {
  events = [],
  linkEventTitles = false,
  expandAllRounds = false,
  hideRoundCollapseControls = false,
  showNoResultsMessage = true,
} = Astro.props;

const normalizedEvents = Array.isArray(events) ? events : [];
const shouldLinkEventTitles = Boolean(linkEventTitles);
const shouldExpandAllRounds = Boolean(expandAllRounds);
const shouldHideRoundCollapseControls = Boolean(hideRoundCollapseControls);
const shouldShowNoResultsMessage = Boolean(showNoResultsMessage);
const STREAMS_FALLBACK_URL = 'https://www.youtube.com/@worldclimbing/streams';
const MONTH_NAMES = [
  'January',
  'February',
  'March',
  'April',
  'May',
  'June',
  'July',
  'August',
  'September',
  'October',
  'November',
  'December',
];

const ROUND_SCHEDULE_STATUS = {
  confirmed: '☑️ Confirmed Schedule',
  provisional: '⏳ Provisional Schedule',
  estimated: '⏳ Estimated Schedule',
};

const ROUND_SCHEDULE_STATUS_TOOLTIPS = {
  confirmed: 'Dates and times are confirmed and unlikely to change',
  provisional: 'Dates and/or times are provisional and can still change',
  estimated: 'Dates and times are estimated and may be adjusted when confirmed',
};

const event_schedule_status_key = (event) => {
  const rounds = Array.isArray(event?.rounds) ? event.rounds : [];
  let numNonQualificationRounds = 0;

  for (const round of rounds) {
    if (round.kind === 'qualification') {
      continue;
    }

    numNonQualificationRounds += 1;

    if (round.schedule_status === 'provisional') {
      return 'provisional';
    }

    if (round.schedule_status === 'estimated') {
      return 'estimated';
    }
  }

  return numNonQualificationRounds > 0 ? 'confirmed' : 'provisional';
};

const event_schedule_status = (event) => {
  const key = event_schedule_status_key(event);
  return ROUND_SCHEDULE_STATUS[key] || ROUND_SCHEDULE_STATUS.provisional;
};

const event_schedule_status_tooltip = (event) => {
  const key = event_schedule_status_key(event);
  return ROUND_SCHEDULE_STATUS_TOOLTIPS[key] || ROUND_SCHEDULE_STATUS_TOOLTIPS.provisional;
};

const month_index_from_starts_at = (startsAt) => {
  const match = /^(\d{4})-(\d{2})-/.exec(startsAt || '');

  if (!match) {
    return null;
  }

  const monthIndex = parseInt(match[2], 10) - 1;

  if (monthIndex < 0 || monthIndex > 11) {
    return null;
  }

  return monthIndex;
};

const parse_date_parts = (value) => {
  const match = /^(\d{4})-(\d{2})-(\d{2})/.exec(value || '');

  if (!match) {
    return null;
  }

  const year = match[1];
  const month = parseInt(match[2], 10) - 1;
  const day = match[3];

  if (month < 0 || month > 11) {
    return null;
  }

  return { year, month, day };
};

const format_event_date = (event) => {
  const startsAt = parse_date_parts(event?.starts_at);
  const endsAt = parse_date_parts(event?.ends_at);

  if (!startsAt || !endsAt) {
    return '';
  }

  return `📅 ${startsAt.day} ${MONTH_NAMES[startsAt.month]} \u2013 ${endsAt.day} ${MONTH_NAMES[endsAt.month]} ${endsAt.year}`;
};

const capitalize = (value) => {
  const normalized = String(value || '');

  if (!normalized) {
    return '';
  }

  return normalized.charAt(0).toUpperCase() + normalized.slice(1);
};

const beautify_disciplines = (disciplines) => {
  const normalized = (Array.isArray(disciplines) ? disciplines : []).map(capitalize);

  if (normalized.length === 0) {
    return '';
  }

  if (normalized.length === 1) {
    return normalized[0];
  }

  const copy = [...normalized];
  const last = copy.pop();

  return `${copy.join(', ')} & ${last}`;
};

const streamable_round_count = (event) => {
  const rounds = Array.isArray(event?.rounds) ? event.rounds : [];

  return rounds.filter((round) => round_will_be_streamed({
    ...round,
    league_name: event.league_name,
  })).length;
};

const parse_iso_date = (value) => {
  const parsed = new Date(value || '');

  if (Number.isNaN(parsed.getTime())) {
    return null;
  }

  return parsed;
};

const ROUND_DATE_FORMATTER = new Intl.DateTimeFormat('en-US', {
  weekday: 'short',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const ROUND_TIME_FORMATTER = new Intl.DateTimeFormat('en-US', {
  hour: '2-digit',
  minute: '2-digit',
  hour12: true,
});

const format_round_date_build = (round) => {
  const date = parse_iso_date(round?.starts_at);

  if (!date) {
    return '';
  }

  return `📅 ${ROUND_DATE_FORMATTER.format(date)}`;
};

const format_round_time_build = (round) => {
  const date = parse_iso_date(round?.starts_at);

  if (!date) {
    return '';
  }

  return `⏰ ${ROUND_TIME_FORMATTER.format(date)}`;
};

const round_local_time_tooltip_build = (round) => {
  const startsAt = String(round?.starts_at || '');
  const match = /T(\d{2}):(\d{2})(?::(\d{2}))?(Z|[+-]\d{2}:\d{2})$/.exec(startsAt);

  if (!match) {
    return '';
  }

  const hour = match[1];
  const minute = match[2];
  const second = match[3] || '00';
  const offset = match[4];
  let utcOffset = '+0';

  if (offset !== 'Z') {
    const sign = offset.charAt(0);
    const rawHours = offset.slice(1, 3);
    const rawMinutes = offset.slice(4, 6);
    const hourOffset = String(parseInt(rawHours, 10));

    utcOffset = rawMinutes === '00' ? `${sign}${hourOffset}` : `${sign}${hourOffset}:${rawMinutes}`;
  }

  return `Local Time: ${hour}:${minute}:${second} (UTC ${utcOffset})`;
};

const event_is_upcoming_build = (round) => {
  const startsAt = parse_iso_date(round?.starts_at);

  if (!startsAt) {
    return false;
  }

  return startsAt.getTime() > Date.now();
};

const poster_url_for_event = (event) => {
  const rounds = Array.isArray(event?.rounds) ? event.rounds : [];

  if (rounds.length === 0) {
    return '';
  }

  const round = rounds[rounds.length - 1];
  const videoId = video_id_from_stream(round);

  return `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
};

const athlete_name_build = (athlete) => `${athlete.first_name} ${athlete.last_name}`;

const start_list_has_photo = (startList) => startList.some((athlete) => Boolean(athlete && athlete.photo_url));

const league_name_without_ifsc = (value) => String(value || '')
  .replace(/\bIFSC\b/gi, '')
  .replace(/\s+/g, ' ')
  .replace('Paraclimbing', 'Para Climbing')
  .trim();
---
{normalizedEvents.map((event) => {
  const eventId = String(event.id);
  const eventNumericId = parseInt(eventId, 10);
  const eventKeyPrefix = Number.isNaN(eventNumericId) ? eventId : eventNumericId.toString(36);
  const monthIndex = month_index_from_starts_at(event.starts_at);
  const panelId = `event-${eventId}`;
  const toggleId = `event-toggle-${eventId}`;
  const headingId = `heading_${eventId}`;
  const startList = Array.isArray(event.start_list) ? event.start_list : [];
  const hasPhotos = start_list_has_photo(startList);
  const startListModalUrl = build_start_list_modal_url(event.season || '', eventId);
  const eventPagePath = build_event_page_path(event.season || '', event);
  const streamCount = streamable_round_count(event);
  const streamLabel = streamCount === 1 ? 'Stream' : 'Streams';
  const posterUrl = poster_url_for_event(event);
  const infosheetUrl = typeof event.infosheet_url === 'string' ? event.infosheet_url.trim() : '';
  const eventScheduleStatus = event_schedule_status(event);
  const eventScheduleStatusTooltip = event_schedule_status_tooltip(event);
  const eventLeagueName = event.league_name;
  const prettyLeagueName = league_name_without_ifsc(event.league_name);
  const roundsPanelClassName = shouldExpandAllRounds ? 'event-rounds-panel' : 'collapse event-rounds-panel';
  const roundsPanelAriaExpanded = shouldExpandAllRounds ? 'true' : 'false';
  const shouldRenderWatchToggle = !shouldHideRoundCollapseControls && !shouldExpandAllRounds;
  const avatarsWithPhoto = startList
    .filter((athlete) => Boolean(athlete && athlete.photo_url))
    .slice(0, 6);

  return (
    <div
      class="card container-xl ifsc-league-card"
      data-event-id={eventId}
      data-event-name={event.name || ''}
      data-event-league-name={eventLeagueName}
      data-event-start-month={monthIndex === null ? undefined : String(monthIndex)}
    >
      <div class="card-header" id={headingId}>
        <div class="rounded-2 event-poster media-shadow-soft" style={posterUrl ? `background-image: url(${posterUrl})` : undefined}></div>

        <div>
          <h5 class="mb-0">
            {shouldLinkEventTitles && eventPagePath ? (
              <a class="event-name" id={toggleId} href={eventPagePath}>
                <span class="event-name-title">{event.name}</span>
                {<small class="event-league-name">{prettyLeagueName}</small>}
              </a>
            ) : shouldRenderWatchToggle ? (
              <button
                class="btn btn-link collapsed event-name"
                id={toggleId}
                data-bs-toggle="collapse"
                data-bs-target={`#${panelId}`}
                aria-expanded={roundsPanelAriaExpanded}
                aria-controls={panelId}
              >
                <span class="event-name-title">{event.name}</span>
                <small class="event-league-name">{prettyLeagueName}</small>
              </button>
            ) : (
              <span class="event-name" id={toggleId}>
                <span class="event-name-title">{event.name}</span>
                <small class="event-league-name">{prettyLeagueName}</small>
              </span>
            )}
          </h5>

          <ul class="event-details">
            <li class="event-date">{format_event_date(event)}</li>
            <li class="event-country">{`📍 ${event.location} (${event.country})`}</li>
            <li class="event-disciplines">{`🧗 ${beautify_disciplines(event.disciplines)}`}</li>
            <li class="event-status">{`💻 ${streamCount} Live ${streamLabel}`}</li>
            <li class="event-schedule-status event-schedule-status-tooltip" title={eventScheduleStatusTooltip}>{eventScheduleStatus}</li>
            <li class:list={['event-start-list', { 'event-start-list-has-avatars': hasPhotos }]}>
              {startList.length === 0 ? (
                '📋 Start List: Pending'
              ) : (
                <button
                  type="button"
                  class="event-start-list-trigger"
                  data-bs-toggle="modal"
                  data-bs-target="#start-list-modal"
                  data-event-id={eventId}
                  data-event-name={event.name || ''}
                  data-start-list-url={startListModalUrl || undefined}
                >
                  {hasPhotos ? (
                    <span class="event-start-list-avatars" aria-label="Start list athletes with profile photos">
                      {avatarsWithPhoto.map((athlete, index) => {
                        const athleteName = athlete_name_build(athlete);
                        const tooltip = athlete.country ? `${athleteName} (${athlete.country})` : athleteName;
                        const stackIndex = avatarsWithPhoto.length - index;
                        const photoSources = athlete_photo_local_sources_build(athlete);

                        if (!photoSources) {
                          return null;
                        }

                        if (photoSources.fallbackSrc) {
                          return (
                            <span class="event-start-list-avatar-chip" style={`--stack-index: ${stackIndex};`}>
                              <img
                                class="event-start-list-avatar event-start-list-avatar-tooltip"
                                src={photoSources.src}
                                width="31"
                                height="31"
                                alt={athleteName}
                                title={tooltip}
                                loading="lazy"
                                referrerpolicy="no-referrer"
                                data-fallback-src={photoSources.fallbackSrc}
                                onerror="handle_start_list_photo_error(this)"
                              />
                            </span>
                          );
                        }

                        return (
                          <span class="event-start-list-avatar-chip" style={`--stack-index: ${stackIndex};`}>
                            <img
                              class="event-start-list-avatar event-start-list-avatar-tooltip"
                              src={photoSources.src}
                              width="31"
                              height="31"
                              alt={athleteName}
                              title={tooltip}
                              loading="lazy"
                              referrerpolicy="no-referrer"
                            />
                          </span>
                        );
                      })}
                    </span>
                  ) : '📋 Start List'}
                </button>
              )}
            </li>
          </ul>
        </div>

        <div class="event-details-clear"></div>

        <div class="event-buttons">
          {shouldRenderWatchToggle ? (
            <button
              type="button"
              class="ifsc-action-button ifsc-action-button-primary"
              data-action="event-watch-toggle"
              data-bs-toggle="collapse"
              data-bs-target={`#${panelId}`}
              aria-expanded={roundsPanelAriaExpanded}
              aria-controls={panelId}
            >🍿 Watch</button>
          ) : null}
          <a class="ifsc-action-button ifsc-action-button-primary" data-action="event-page" href={event.event_url} role="button" target="_blank" rel="noopener">Event Page <img src="img/external-link.svg" width="12" height="12" alt="External link" /></a>
          {infosheetUrl ? (
            <a
              class="ifsc-action-button ifsc-action-button-primary"
              data-action="event-infosheet"
              href={infosheetUrl}
              role="button"
              target="_blank"
              rel="noopener"
              aria-label="Event infosheet PDF"
              title="Event infosheet PDF"
            ><img src="img/pdf-icon.svg" width="18" height="18" alt="PDF" /></a>
          ) : null}
        </div>

        <div id={panelId} class={roundsPanelClassName} aria-labelledby={toggleId} data-bs-parent={!shouldExpandAllRounds ? '#accordion' : undefined}>
          <ul class="card-body list-group">
            {(Array.isArray(event.rounds) ? event.rounds : []).map((round, roundIndex) => {
              const roundKey = `${eventKeyPrefix}.${roundIndex.toString(36)}`;
              const streamUrl = typeof round.stream_url === 'string' ? round.stream_url : '';
              const fallbackUrl = streamUrl || STREAMS_FALLBACK_URL;
              const hasStreamUrl = Boolean(streamUrl);
              const isUpcoming = event_is_upcoming_build(round);
              const startsInText = event_schedule_status(round);
              const roundLocalTimeTooltip = round_local_time_tooltip_build(round);
              const showReminder = isUpcoming;
              const videoId = video_id_from_stream(round);

              return (
                <li
                  class="event-round-card"
                  data-round-key={roundKey}
                  data-round-name={round.name || ''}
                  data-round-starts-at={round.starts_at || ''}
                  data-round-ends-at={round.ends_at || ''}
                  data-round-kind={round.kind || ''}
                  data-round-disciplines={(Array.isArray(round.disciplines) ? round.disciplines : []).join(',')}
                  data-round-categories={(Array.isArray(round.categories) ? round.categories : []).join(',')}
                >
                  <div class="youtube-thumbnail media-shadow-soft" data-youtube-video-id={videoId} style={`background-image: url(https://img.youtube.com/vi/${videoId}/0.jpg);`}>
                    <button
                      class="youtube-play-button"
                      type="button"
                      aria-label="Watch stream"
                      data-round-stream-url={hasStreamUrl ? streamUrl : undefined}
                    ></button>
                  </div>

                  <div class="d-flex align-items-center round-details">
                    <div class="round-copy">
                      <h6 class="round-name">{round.name}</h6>
                      <h6 class="round-date">{format_round_date_build(round)}</h6>
                      <h6 class="round-time" title={roundLocalTimeTooltip || undefined}>{format_round_time_build(round)}</h6>
                      <p class="round-starts-in">{startsInText}</p>
                    </div>

                    <div class="watch-button">
                      <a
                        class="ifsc-action-button ifsc-action-button-primary"
                        data-action="round-stream"
                        href={fallbackUrl}
                        rel="noopener"
                        target="_blank"
                        data-round-stream-url={hasStreamUrl ? streamUrl : undefined}
                      >🍿 Watch</a>
                      {showReminder ? (
                        <a class="ifsc-action-button ifsc-action-button-primary button-reminder" href="https://github.com/sportclimbing/ifsc-calendar/wiki" rel="noopener" role="button" target="_blank" data-bs-toggle="modal" data-bs-target="#calendar-modal">📆 Set Reminder</a>
                      ) : (
                        <a class="ifsc-action-button ifsc-action-button-primary button-results" href={`https://ifsc.results.info/event/${eventId}`} role="button" target="_blank" rel="noopener">🏆 Results</a>
                      )}
                    </div>
                  </div>
                </li>
              );
            })}
          </ul>
        </div>
      </div>
    </div>
  );
})}
{shouldShowNoResultsMessage ? <div class="no-results" id="no-results-message" hidden><span class="no-results-icon" aria-hidden="true">⚠️</span><span class="no-results-text">No results. Please adjust filters above!</span></div> : null}
