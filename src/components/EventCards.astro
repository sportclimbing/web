---
import EventCard from './EventCard.astro';

const {
  events = [],
  linkEventTitles = false,
  showNoResultsMessage = true,
} = Astro.props;

const normalizedEvents = Array.isArray(events) ? events : [];
const shouldLinkEventTitles = Boolean(linkEventTitles);
const shouldShowNoResultsMessage = Boolean(showNoResultsMessage);
---
{normalizedEvents.map((event) => (
  <EventCard 
    event={event} 
    shouldLinkEventTitles={shouldLinkEventTitles} 
  />
))}

{shouldShowNoResultsMessage && (
  <div class="no-results" id="no-results-message" hidden>
      <div class="bg-surface-container-low p-8 rounded-xl text-center border border-outline-variant/20">
          <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-4">search_off</span>
          <p class="text-xl font-headline font-bold mb-2 no-results-text">No events found</p>
          <p class="text-on-surface-variant">Please adjust your filters to see more results.</p>
      </div>
  </div>
)}
