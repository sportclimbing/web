<!-- Calendar Sync Banner -->
<section class="bg-surface-container-lowest border-y border-outline-variant/15 py-20">
    <div class="max-w-screen-2xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-12">
        <div class="max-w-xl">
            <h3 class="text-4xl font-black font-headline uppercase leading-tight">Never Miss a Finals Stream</h3>
            <p class="text-on-surface-variant text-lg mt-4">Sync the full World Climbing season directly to your calendar app and get automatic updates for every live stream and competition.</p>
        </div>
        <div class="flex w-full md:w-auto gap-3">
            <button class="kinetic-gradient text-on-primary-fixed px-10 py-5 rounded-xl font-bold uppercase text-sm tracking-widest whitespace-nowrap shadow-lg hover:shadow-primary/20 transition-all flex items-center gap-3 calendar-sync-tooltip" data-bs-toggle="modal" data-bs-target="#calendar-modal">
                <span class="material-symbols-outlined text-base">sync</span>
                Sync with Calendar
            </button>
        </div>
    </div>
</section>
