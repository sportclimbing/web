---
import { round_will_be_streamed } from '../js/app/helpers/core.js';

const {
  round,
  event,
  formatRoundDate,
  formatRoundTime,
  formatRoundEndTime,
  hasStreamUrl,
  isUpcoming,
  isFinished,
  thumbnailUrl,
  isHiddenNoStream = false,
} = Astro.props;

const showReminder = isUpcoming;
const roundKey = `${round.kind || ''}-${(Array.isArray(round.disciplines) ? round.disciplines : []).sort().join(',')}-${(Array.isArray(round.categories) ? round.categories : []).sort().join(',')}`;

const willBeStreamed = round_will_be_streamed(round, event);
const isDimmed = !willBeStreamed || (isFinished && !hasStreamUrl);
const liveBadgeClass = 'text-primary bg-primary/10';
const watchButtonClass = 'border border-primary text-primary hover:bg-primary/10';

---
<li class={`flex flex-row flex-wrap items-start sm:items-center gap-3 sm:gap-6 p-3 sm:p-5 bg-surface-container-high rounded-xl group cursor-pointer hover:bg-surface-container-highest transition-colors event-round-card ifsc-event ${isDimmed ? 'opacity-80' : ''} ${isHiddenNoStream ? 'hidden unstreamed-round' : ''}`}
     data-round-kind={round.kind}
     data-round-disciplines={(Array.isArray(round.disciplines) ? round.disciplines : []).join(',')}
     data-round-categories={(Array.isArray(round.categories) ? round.categories : []).join(',')}
     data-round-name={round.name}
     data-round-starts-at={round.starts_at}
     data-round-ends-at={round.ends_at}
     data-round-key={roundKey}>
    
    <div class="w-24 h-16 sm:w-32 sm:h-20 bg-black rounded-lg overflow-hidden flex-shrink-0 relative">
        {thumbnailUrl ? (
            <img class={`w-full h-full object-cover ${isDimmed ? 'opacity-50' : 'opacity-80'}`} src={thumbnailUrl} alt="Stream Thumbnail" loading="lazy" />
        ) : (
            <div class="w-full h-full flex items-center justify-center bg-surface-container-highest text-on-surface-variant"><span class="material-symbols-outlined">live_tv</span></div>
        )}
        {hasStreamUrl && (
        <div class="absolute inset-0 flex items-center justify-center">
            <span class="material-symbols-outlined text-white text-3xl opacity-0 group-hover:opacity-100 transition-opacity stream-icon">play_arrow</span>
        </div>
        )}
        {hasStreamUrl && <button class="youtube-play-button" type="button" aria-label="Watch stream" data-action="round-stream" data-round-stream-url={round.stream_url}></button>}
        <div class="absolute top-1 left-1 flex gap-1">
            {!willBeStreamed && <span class="text-[8px] text-on-surface-variant font-bold uppercase tracking-widest bg-surface-container-lowest px-1.5 py-0.5 rounded">No Stream</span>}
            {willBeStreamed && <span class={`text-[8px] ${liveBadgeClass} font-bold uppercase tracking-widest px-1.5 py-0.5 rounded live-badge hidden`}>Live Now</span>}
            <span class="text-[8px] text-green-950 font-bold uppercase tracking-widest bg-green-400 px-1.5 py-0.5 rounded next-event-badge hidden">Next Event</span>
            {willBeStreamed && isUpcoming && <span class="text-[8px] text-on-tertiary font-bold uppercase tracking-widest bg-tertiary px-1.5 py-0.5 rounded upcoming-badge">Upcoming</span>}
            {willBeStreamed && !isUpcoming && <span class="text-[8px] text-on-primary-fixed font-bold uppercase tracking-widest bg-primary px-1.5 py-0.5 rounded replay-badge">Replay</span>}
        </div>
    </div>

    <div class="flex-1 min-w-0 flex flex-col">
        <h4 class={`font-bold text-xs sm:text-sm lg:text-lg uppercase leading-tight truncate round-name mb-2 ${isDimmed ? 'text-on-surface-variant' : 'text-on-surface'}`}>{round.name}</h4>
        <div class="text-[11px] sm:text-[13px] text-on-surface-variant font-medium sm:mb-1 flex flex-col gap-0.5">
            <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[13px] sm:text-[15px] text-primary">calendar_today</span><span class="round-date">{formatRoundDate}</span></span>
            <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[13px] sm:text-[15px] text-primary">schedule</span><span class="round-time">{formatRoundTime}</span>{formatRoundEndTime && <span class="round-end-time"> - {formatRoundEndTime}</span>} <span class="round-starts-in hidden ml-2"></span></span>
        </div>
    </div>

    <div class={`${willBeStreamed ? 'flex' : 'hidden sm:flex'} gap-3 sm:ml-auto w-full sm:w-auto round-actions`}>
           {willBeStreamed && hasStreamUrl && <a href={round.stream_url}
                   class={`text-sm font-bold flex flex-1 sm:flex-none justify-center items-center gap-2 px-4 py-2 rounded-lg transition-colors ${watchButtonClass} whitespace-nowrap round-stream-button`}
                   data-action="round-stream"
                   data-round-stream-url={round.stream_url}>
               <span class="material-symbols-outlined text-[18px]">{isFinished ? 'replay' : 'play_circle'}</span> {isFinished ? 'REPLAY' : 'WATCH'}
           </a>}
           {willBeStreamed && !hasStreamUrl && <button type="button"
                   class={`text-sm font-bold flex flex-1 sm:flex-none justify-center items-center gap-2 px-4 py-2 rounded-lg transition-colors ${watchButtonClass} whitespace-nowrap round-stream-button`}
                   data-action="round-stream"
                   data-round-stream-url={round.stream_url}>
               <span class="material-symbols-outlined text-[18px]">{isFinished ? 'replay' : 'play_circle'}</span> {isFinished ? 'REPLAY' : 'WATCH'}
           </button>}

    </div>
</li>
